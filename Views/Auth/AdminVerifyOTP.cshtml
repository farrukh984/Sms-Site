@{
    ViewData["Title"] = "Admin Login Verification | HiChat SMS Platform";
    Layout = "~/Views/Shared/_Layout_RentalX.cshtml";
}

<!-- Video Background -->
<div class="rx-video-wrapper">
    <video autoplay muted loop playsinline preload="auto">
        <source src="~/vedios/sms-login.webm" type="video/webm">
        <source src="~/vedios/sms-login.mp4" type="video/mp4">
    </video>
    <div class="rx-video-overlay"></div>
</div>

<div class="rx-hero-section">
    <div class="container">
        <div class="row align-items-center justify-content-center">

            <!-- Left Content - Branding -->
            <div class="col-lg-7 animate__animated animate__fadeInLeft">
                <div class="rx-brand-logo-container d-flex align-items-center gap-3 mb-3">
                    <div class="rx-logo-box">
                        <i class="fas fa-comment-dots fs-4 text-white"></i>
                    </div>
                    <h1 class="rx-brand-text m-0">SMS<span class="rx-brand-x">SITE</span></h1>
                </div>
                <p class="lead text-white-50 mb-4" style="font-size: 1.25rem; max-width: 90%;">
                    Verify admin login to unlock full access to the Dashboard.
                </p>
                <div class="rx-stats-container d-none d-lg-flex gap-4">
                    <div class="rx-stat-item"><h4>50K+</h4><small>Active Users</small></div>
                    <div class="rx-stat-item"><h4>99.9%</h4><small>Uptime SLA</small></div>
                    <div class="rx-stat-item"><h4>24/7</h4><small>Support</small></div>
                </div>
            </div>

            <!-- Right Content - Verify OTP Form -->
            <div class="col-lg-5 animate__animated animate__fadeInRight">
                <div class="rx-glass-card">
                    <div class="text-center mb-4">
                        <div class="rx-logo-box mb-3 mx-auto" style="width: 60px; height: 60px;">
                            <i class="fas fa-shield-alt fs-3 text-white"></i>
                        </div>
                        <h3 class="fw-bold">Admin OTP Verification</h3>
                        <p class="text-white-50">
                            Code sent to <span class="text-white">@(TempData["AdminEmail"] ?? "admin email")</span>
                        </p>
                    </div>

                    @if (ViewBag.Error != null || TempData["Error"] != null)
                    {
                        <div class="rx-alert-err mb-3" style="background: rgba(255,59,48,0.1); color: #ff3b30; padding: 12px; border-radius: 12px; font-size: 14px; text-align: center; border: 1px solid rgba(255,59,48,0.3);">
                            <i class="fas fa-exclamation-circle me-2"></i> @(ViewBag.Error ?? TempData["Error"])
                        </div>
                    }
                    @if (TempData["SuccessMessage"] != null)
                    {
                        <div class="rx-alert-success mb-3" style="background: rgba(37,211,102,0.1); color: #25D366; padding: 12px; border-radius: 12px; font-size: 14px; text-align: center; border: 1px solid rgba(37,211,102,0.3);">
                            <i class="fas fa-check-circle me-2"></i> @TempData["SuccessMessage"]
                        </div>
                    }

                    <form asp-action="AdminVerifyOTP" method="post" id="otpForm" onsubmit="combineOtp()">
                        @Html.AntiForgeryToken()

                        <div class="d-flex justify-content-center gap-2 mb-4">
                            <input type="text" class="rx-input text-center fw-bold" style="width: 55px; height: 60px; font-size: 1.5rem; padding: 0;" maxlength="1" pattern="[0-9]" inputmode="numeric" onkeyup="otpJump(this, 'o2', '')" id="o1" autocomplete="off" required />
                            <input type="text" class="rx-input text-center fw-bold" style="width: 55px; height: 60px; font-size: 1.5rem; padding: 0;" maxlength="1" pattern="[0-9]" inputmode="numeric" onkeyup="otpJump(this, 'o3', 'o1')" id="o2" autocomplete="off" required />
                            <input type="text" class="rx-input text-center fw-bold" style="width: 55px; height: 60px; font-size: 1.5rem; padding: 0;" maxlength="1" pattern="[0-9]" inputmode="numeric" onkeyup="otpJump(this, 'o4', 'o2')" id="o3" autocomplete="off" required />
                            <input type="text" class="rx-input text-center fw-bold" style="width: 55px; height: 60px; font-size: 1.5rem; padding: 0;" maxlength="1" pattern="[0-9]" inputmode="numeric" onkeyup="otpJump(this, '', 'o3')" id="o4" autocomplete="off" required />
                        </div>

                        <input type="hidden" name="otp" id="otpValue" />

                        <div class="text-center mb-4">
                            <p class="text-white-50 small mb-0">
                                Resend code in <span id="timer" style="color: var(--rx-red); font-weight: 600;">53</span> s
                            </p>
                        </div>

                        <button type="submit" class="rx-btn-signin w-100">
                            <i class="fas fa-check-circle me-2"></i> Verify Admin Login
                        </button>
                    </form>

                    <div class="rx-divider"></div>

                    <div class="text-center">
                        <p class="text-white-50 small mb-0">Wrong email address?</p>
                        <a href="/Auth/Login" class="rx-link fw-bold">
                            <i class="fas fa-sign-in-alt me-2"></i> Back to Login
                        </a>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>

<script>
    function otpJump(current, nextId, prevId) {
        if (current.value.length === 1 && nextId !== '') {
            document.getElementById(nextId).focus();
        }
        if (current.value.length === 0 && prevId !== '') {
            document.getElementById(prevId).focus();
        }
    }

    function combineOtp() {
        var code = '';
        for (var i = 1; i <= 4; i++) {
            code += document.getElementById('o' + i).value;
        }
        document.getElementById('otpValue').value = code;
    }

    // Countdown Timer
    var seconds = 53;
    var timerEl = document.getElementById('timer');
    var interval = setInterval(function() {
        seconds--;
        timerEl.textContent = seconds;
        if (seconds <= 0) {
            clearInterval(interval);
            timerEl.parentNode.innerHTML = '<a href="/Auth/ResendAdminOTP" style="color: var(--rx-red); text-decoration: none; font-weight: 600;">Resend Code</a>';
        }
    }, 1000);

    // Auto-focus first input
    window.onload = function() {
        document.getElementById('o1').focus();
    };
</script>
