@model Site.Models.Users
@{
    ViewData["Title"] = "Login | HiChat SMS Platform";
    Layout = "~/Views/Shared/_Layout_RentalX.cshtml";
}

<!-- Video Background -->
<div class="rx-video-wrapper">
    <video autoplay muted loop playsinline preload="auto">
        <source src="~/vedios/sms-login.webm" type="video/webm">
        <source src="~/vedios/sms-login.mp4" type="video/mp4">
    </video>
    <div class="rx-video-overlay"></div>
</div>

<div class="rx-hero-section">
    <div class="container">
        <div class="row align-items-center">

            <!-- Left Content - Branding -->
            <div class="col-lg-7 animate__animated animate__fadeInLeft">
                <div class="rx-brand-logo-container d-flex align-items-center gap-3 mb-3">
                    <div class="rx-logo-box">
                        <i class="fas fa-comment-dots fs-4 text-white"></i>
                    </div>
                    <h1 class="rx-brand-text m-0">SMS<span class="rx-brand-x">SITE</span></h1>
                </div>
                <p class="lead text-white-50 mb-4" style="font-size: 1.25rem; max-width: 90%;">
                    Welcome back to the world's most powerful SMS management platform. Send, manage & track your messages with enterprise-grade reliability.
                </p>
                <div class="rx-stats-container d-none d-lg-flex gap-4">
                    <div class="rx-stat-item"><h4>50K+</h4><small>Active Users</small></div>
                    <div class="rx-stat-item"><h4>99.9%</h4><small>Uptime SLA</small></div>
                    <div class="rx-stat-item"><h4>24/7</h4><small>Support</small></div>
                </div>
            </div>

            <!-- Right Content - Login Form -->
            <div class="col-lg-5 animate__animated animate__fadeInRight">
                <div class="rx-glass-card">
                    <div class="text-center mb-4">
                        <h3 class="fw-bold">Welcome Back</h3>
                        <p class="text-white-50">Sign in to your HiChat account</p>
                    </div>

                    @if (ViewBag.Error != null)
                    {
                        <div class="rx-alert-err">
                            <i class="fas fa-exclamation-circle me-2"></i> @ViewBag.Error
                        </div>
                    }
                    @if (ViewBag.Message != null)
                    {
                        <div class="rx-alert-ok">
                            <i class="fas fa-check-circle me-2"></i> @ViewBag.Message
                        </div>
                    }

                    <form asp-action="Login" method="post" autocomplete="off">
                        @Html.AntiForgeryToken()

                        <div class="mb-3">
                            <label class="rx-form-label">
                                <i class="far fa-envelope me-2" style="color: var(--rx-red);"></i>Email / Username / Mobile
                            </label>
                            <input asp-for="Username" class="rx-input" placeholder="Enter your identifier" required />
                        </div>

                        <div class="mb-4">
                            <label class="rx-form-label">
                                <i class="fas fa-lock me-2" style="color: var(--rx-red);"></i>Password
                            </label>
                            <input asp-for="Password" type="password" class="rx-input" placeholder="••••••••" required />
                        </div>

                        <!-- Remember Me & Forgot Password -->
                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <div class="form-check">
                                <input class="form-check-input rx-check" type="checkbox" name="rememberMe" id="rememberMe" />
                                <label class="form-check-label text-white-50 small" for="rememberMe">
                                    Keep me signed in
                                </label>
                            </div>
                            <a href="/Auth/ForgotPassword" class="rx-link small">Forgot Password?</a>
                        </div>

                        <button type="submit" class="rx-btn-signin">
                            <i class="fas fa-sign-in-alt me-2"></i> Sign In
                        </button>
                    </form>

                    <div class="rx-divider"></div>

                    <!-- Social Login Buttons -->
                    <div class="row g-2 mb-3">
                        <div class="col-6">
                            <a href="/Auth/GoogleLogin" class="rx-btn-soc w-100 d-flex align-items-center justify-content-center gap-2">
                                <img src="https://www.google.com/favicon.ico" width="16" alt="Google" /> Google
                            </a>
                        </div>
                        <div class="col-6">
                            <a href="/Auth/FacebookLogin" class="rx-btn-soc w-100 d-flex align-items-center justify-content-center gap-2">
                                <i class="fab fa-facebook-f text-primary"></i> Facebook
                            </a>
                        </div>
                    </div>

                    <!-- Sign Up Link -->
                    <div class="text-center">
                        <p class="text-white-50 small mb-0">Don't have an account?</p>
                        <a href="/Auth/Register" class="rx-link fw-bold">
                            Create Account <i class="fas fa-arrow-right ms-2"></i>
                        </a>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>
