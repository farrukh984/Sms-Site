@model Site.Models.Users
@{
    ViewData["Title"] = "Create Account | HiChat SMS Platform";
    Layout = "~/Views/Shared/_Layout_RentalX.cshtml";
}

<!-- Video Background -->
<div class="rx-video-wrapper">
    <video autoplay muted loop playsinline preload="auto">
        <source src="~/vedios/sms-login.webm" type="video/webm">
        <source src="~/vedios/sms-login.webm" type="video/mp4">
    </video>
    <div class="rx-video-overlay"></div>
</div>

<div class="rx-hero-section">
    <div class="container">
        <div class="row align-items-center">

            <!-- Left Content - Branding -->
            <div class="col-lg-7 animate__animated animate__fadeInLeft">
                <div class="rx-brand-logo-container d-flex align-items-center gap-3 mb-3">
                    <div class="rx-logo-box">
                        <i class="fas fa-comment-dots fs-4 text-white"></i>
                    </div>
                    <h1 class="rx-brand-text m-0">SMS<span class="rx-brand-x">SITE</span></h1>
                </div>
                <p class="lead text-white-50 mb-4" style="font-size: 1.25rem; max-width: 90%;">
                    Join the world's most powerful SMS management platform. Create your account to send, manage, and track your messages with enterprise-grade reliability.
                </p>
            </div>

            <!-- Right Content - Registration Form -->
            <div class="col-lg-5 animate__animated animate__fadeInRight">
                <div class="rx-glass-card">
                    <div class="text-center mb-4">
                        <h3 class="fw-bold">Create Account</h3>
                        <p class="text-white-50">Fill in the details to sign up</p>
                    </div>

                    @if (ViewBag.Error != null)
                    {
                        <div class="rx-alert-err">
                            <i class="fas fa-exclamation-circle me-2"></i> @ViewBag.Error
                        </div>
                    }


                    <form asp-action="Register" method="post" autocomplete="off">
                        @Html.AntiForgeryToken()

                        <div class="mb-3">
                            <label class="rx-form-label">
                                <i class="far fa-user me-2" style="color: var(--rx-red);"></i>Username
                            </label>
                            <input asp-for="Username" class="rx-input" placeholder="e.g. janesmith" required />
                        </div>

                        <div class="mb-3">
                            <label class="rx-form-label">
                                <i class="far fa-envelope me-2" style="color: var(--rx-red);"></i>Email Address
                            </label>
                            <input asp-for="Email" type="email" class="rx-input" placeholder="e.g. jane@domain.com" required />
                        </div>

                        <div class="mb-3">
                            <label class="rx-form-label">
                                <i class="fas fa-mobile-alt me-2" style="color: var(--rx-red);"></i>Mobile Number
                            </label>
                            <input asp-for="MobileNumber" type="tel" class="rx-input" placeholder="e.g. 03001234567" required />
                        </div>

                        <div class="mb-3">
                            <label class="rx-form-label">
                                <i class="fas fa-lock me-2" style="color: var(--rx-red);"></i>Password
                            </label>
                            <input asp-for="Password" type="password" class="rx-input" placeholder="Min. 6 characters" required />
                        </div>

                        <div class="mb-4">
                            <label class="rx-form-label">
                                <i class="fas fa-lock me-2" style="color: var(--rx-red);"></i>Confirm Password
                            </label>
                            <input asp-for="ConfirmPassword" type="password" class="rx-input" placeholder="Re-type password" required />
                        </div>

                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <div class="form-check">
                                <input class="form-check-input rx-check" type="checkbox" required />
                                <label class="form-check-label text-white-50 small">
                                    I agree to the Terms &amp; Privacy Policy
                                </label>
                            </div>
                        </div>

                        <button type="submit" class="rx-btn-signin mb-3">
                            <i class="fas fa-user-plus me-2"></i> Sign Up
                        </button>
                    </form>

                    <div class="rx-divider"><span></span></div>

                    <!-- Social Login Buttons -->
                    <div class="row g-2 mb-3">
                        <div class="col-6">
                            <a href="@Url.Action("ExternalLogin", "Auth", new { provider = "Google" })" 
class="rx-btn-soc w-100 d-flex align-items-center justify-content-center gap-2 py-2">
                                <img src="https://www.gstatic.com/firebasejs/ui/2.0.0/images/auth/google.svg" 
width="18" alt="Google" /> Google
                            </a>
                        </div>
                        <div class="col-6">
                            <a href="@Url.Action("ExternalLogin", "Auth", new { provider = "Facebook" })" 
class="rx-btn-soc w-100 d-flex align-items-center justify-content-center gap-2 py-2">
                                <i class="fab fa-facebook-f" style="color: #1877F2;"></i> Facebook
                            </a>
                        </div>
                    </div>

                    <!-- Sign In Link -->
                    <div class="text-center mt-3">
                        <p class="text-white-50 small mb-0">Already have an account?</p>
                        <a href="/Auth/Login" class="rx-link fw-bold">
                            <i class="fas fa-sign-in-alt me-2"></i> Sign In
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
