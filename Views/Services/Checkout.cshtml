@model List<Site.Models.Service>
@{
    ViewData["Title"] = "Checkout";
    Layout = "~/Views/Shared/_Layout_Chat.cshtml";
    string ids = ViewBag.SelectedIds ?? "";
    decimal total = Model.Sum(s => s.Price);
}

@section Styles {
<style>
    .checkout-page { padding: 24px; max-width: 500px; margin: 0 auto; }
    .co-header { text-align: center; margin-bottom: 28px; }
    .co-header h1 { font-size: 24px; font-weight: 800; color: var(--text-primary); }
    .co-header p  { color: var(--text-secondary); font-size: 14px; margin-top: 4px; }

    .order-card {
        background: rgba(255,255,255,0.03);
        border: 1px solid rgba(255,255,255,0.07);
        border-radius: 20px; padding: 20px;
        margin-bottom: 20px;
    }
    .order-card h3 { font-size: 12px; font-weight: 700; color: rgba(255,255,255,0.4); text-transform: uppercase; letter-spacing: 1px; margin-bottom: 14px; }
    .order-row { display: flex; justify-content: space-between; align-items: center; padding: 10px 0; border-bottom: 1px solid rgba(255,255,255,0.05); font-size: 14px; }
    .order-row:last-child { border-bottom: none; }
    .order-row .name { display: flex; align-items: center; gap: 10px; color: var(--text-primary); font-weight: 500; }
    .order-row .price { color: var(--accent-red); font-weight: 700; }
    .total-row { display: flex; justify-content: space-between; align-items: center; padding: 14px 20px; background: rgba(255,77,79,0.06); border: 1px solid rgba(255,77,79,0.2); border-radius: 14px; margin-bottom: 20px; }
    .total-row span { color: rgba(255,255,255,0.6); font-size: 14px; }
    .total-row strong { color: #fff; font-size: 24px; font-weight: 800; }

    .payment-card {
        background: rgba(255,255,255,0.03);
        border: 1px solid rgba(255,255,255,0.07);
        border-radius: 20px; padding: 24px;
        margin-bottom: 20px;
    }
    .payment-card h3 { font-size: 12px; font-weight: 700; color: rgba(255,255,255,0.4); text-transform: uppercase; letter-spacing: 1px; margin-bottom: 16px; }
    .inp-field {
        display: flex; align-items: center;
        background: rgba(255,255,255,0.04);
        border: 1px solid rgba(255,255,255,0.1);
        border-radius: 12px; padding: 0 16px; height: 50px;
        margin-bottom: 12px;
        transition: border-color 0.2s;
    }
    .inp-field:focus-within { border-color: var(--accent-red); }
    .inp-field i { color: rgba(255,255,255,0.3); font-size: 15px; margin-right: 10px; width: 18px; }
    .inp-field input { background: transparent; border: none; outline: none; color: #fff; font-size: 14px; font-family: inherit; width: 100%; }
    .inp-row { display: flex; gap: 12px; }
    .inp-row .inp-field { flex: 1; }

    .pay-btn {
        width: 100%; height: 54px; background: var(--accent-red);
        border: none; border-radius: 16px; color: #fff;
        font-size: 16px; font-weight: 700; cursor: pointer;
        display: flex; align-items: center; justify-content: center; gap: 10px;
        box-shadow: 0 8px 28px rgba(255,77,79,0.35); transition: 0.2s;
    }
    .pay-btn:hover { transform: translateY(-2px); }
    .pay-btn.success { background: #25d366; box-shadow: 0 8px 28px rgba(37,211,102,0.3); }

    .secure-note { text-align: center; font-size: 12px; color: rgba(255,255,255,0.3); margin-top: 14px; }
    .card-brands { display: flex; gap: 8px; justify-content: flex-end; margin-bottom: 12px; }
    .card-brands img { height: 20px; opacity: 0.6; }
</style>
}

<div class="checkout-page">
    <a href="/Services" style="display:inline-flex;align-items:center;gap:8px;color:var(--accent-red);font-size:13px;font-weight:600;text-decoration:none;margin-bottom:20px;">
        <i class="fas fa-arrow-left"></i> Back to Services
    </a>

    <div class="co-header">
        <i class="fas fa-shield-alt" style="font-size:32px;color:var(--accent-red);margin-bottom:10px;display:block;"></i>
        <h1>Secure Checkout</h1>
        <p>Complete your payment to unlock selected services</p>
    </div>

    <!-- Order Summary -->
    <div class="order-card">
        <h3><i class="fas fa-receipt" style="margin-right:6px;"></i>Order Summary</h3>
        @foreach (var svc in Model)
        {
            <div class="order-row">
                <span class="name"><i class="@(svc.IconClass ?? "fas fa-star")" style="color:var(--accent-red);"></i> @svc.Title</span>
                <span class="price">$@svc.Price.ToString("0.00")</span>
            </div>
        }
    </div>

    <div class="total-row">
        <span>Total to Pay</span>
        <strong>$@total.ToString("0.00")</strong>
    </div>

    <!-- Payment -->
    <div class="payment-card">
        <h3><i class="fas fa-credit-card" style="margin-right:6px;"></i>Payment Details</h3>
        <div class="card-brands">
            <img src="https://upload.wikimedia.org/wikipedia/commons/thumb/2/2a/Mastercard-logo.svg/120px-Mastercard-logo.svg.png" alt="MC" />
            <img src="https://upload.wikimedia.org/wikipedia/commons/thumb/5/5e/Visa_Inc._logo.svg/120px-Visa_Inc._logo.svg.png" alt="Visa" />
        </div>
        <div class="inp-field">
            <i class="fas fa-credit-card"></i>
            <input type="text" id="cardNum" placeholder="Card Number" value="•••• •••• •••• 4242" readonly />
        </div>
        <div class="inp-row">
            <div class="inp-field"><input type="text" placeholder="MM/YY" value="12/28" readonly /></div>
            <div class="inp-field"><input type="password" placeholder="CVV" value="123" readonly /></div>
        </div>
        <div class="inp-field">
            <i class="fas fa-user"></i>
            <input type="text" placeholder="Cardholder Name" value="@(User.Identity?.Name ?? "John Doe")" readonly />
        </div>
    </div>

    <button class="pay-btn" id="payBtn" onclick="processPayment()">
        <i class="fas fa-lock"></i> Pay $@total.ToString("0.00") & Unlock
    </button>

    <p class="secure-note"><i class="fas fa-lock" style="margin-right:4px;"></i> 256-bit SSL encrypted &nbsp;·&nbsp; Your payment is secure</p>
</div>

@section Scripts {
<script>
    const serviceIds = '@ids';

    function processPayment() {
        const btn = document.getElementById('payBtn');
        btn.disabled = true;
        btn.innerHTML = '<i class="fas fa-circle-notch fa-spin"></i> Processing Payment...';

        setTimeout(() => {
            btn.innerHTML = '<i class="fas fa-check-circle" style="font-size:20px;"></i> Verifying...';

            fetch('/Services/Pay', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: 'ids=' + encodeURIComponent(serviceIds)
            })
            .then(r => r.json())
            .then(data => {
                if (data.success) {
                    btn.className = 'pay-btn success';
                    btn.innerHTML = '<i class="fas fa-check-circle" style="font-size:22px;"></i> Payment Successful!';
                    setTimeout(() => {
                        window.location.href = '/Services';
                    }, 1800);
                } else {
                    btn.disabled = false;
                    btn.className = 'pay-btn';
                    btn.innerHTML = '<i class="fas fa-lock"></i> Try Again';
                }
            });
        }, 2200);
    }
</script>
}
