@model List<Site.Models.Service>
@{
    ViewData["Title"] = "Services Hub";
    Layout = "~/Views/Shared/_Layout_Chat.cshtml";
    var owned = ViewBag.AlreadyOwned as List<int> ?? new List<int>();
}

@section Styles {
<style>
    .svc-checkbox {
        width: 20px;
        height: 20px;
        border-radius: 6px;
        border: 2px solid var(--text-muted);
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: all 0.2s;
    }
    .chat-item.selected .svc-checkbox {
        background: var(--accent-red);
        border-color: var(--accent-red);
        color: #fff;
    }
    .chat-item.owned .svc-checkbox {
        background: #25d366;
        border-color: #25d366;
        color: #fff;
        cursor: default;
    }
    
    @@media (max-width: 768px) {
        .chat-workspace-panel {
            display: none !important;
        }
        .chat-list-panel {
            width: 100% !important;
            border-right: none !important;
        }
    }
</style>
}

<div class="chat-app-layout">
    <!-- Column 1 (Far Left Navigation Menu) -->
    @await Html.PartialAsync("_NavSidebar", "Services")

    <!-- Column 2 (Middle Services List) -->
    <div class="chat-list-panel" style="width: 380px;">
        <div style="display: flex; flex-direction: column; height: 100%;">
            <div class="chat-panel-header">
                <div class="chat-panel-title-bar">
                    <div style="display:flex; align-items:center; gap:12px;">
                        <div style="background: rgba(255, 77, 79, 0.1); width: 36px; height: 36px; border-radius: 50%; display: flex; align-items: center; justify-content: center;">
                            <i class="fas fa-cubes" style="color: var(--accent-red); font-size: 16px;"></i>
                        </div>
                        <h2>Services</h2>
                    </div>
                </div>

                <div class="chat-search-container">
                    <input type="text" id="svcSearchInput" placeholder="Search services..." onkeyup="filterServices()" />
                </div>

                <div class="chat-filters">
                    <div class="chat-filter-pill active" onclick="filterType('all', this)">All</div>
                    <div class="chat-filter-pill" onclick="filterType('active', this)">Active</div>
                    <div class="chat-filter-pill" onclick="filterType('locked', this)">Locked</div>
                </div>
            </div>

            <div class="chat-list-scrollable" id="servicesContainer">
                @if (!Model.Any())
                {
                    <div style="text-align: center; color: var(--text-muted); margin-top: 40px; font-size: 14px;">No services available.</div>
                }
                else
                {
                    @foreach (var svc in Model)
                    {
                        bool isOwned = owned.Contains(svc.Id);
                        <div class="chat-item service-list-item @(isOwned ? "owned" : "")"
                             id="svc-item-@svc.Id"
                             data-id="@svc.Id"
                             data-title="@svc.Title.ToLower()"
                             data-desc="@(svc.Description?.ToLower() ?? "")"
                             data-owned="@isOwned.ToString().ToLower()"
                             data-price="@svc.Price"
                             onclick="toggleSelect('@svc.Id')">
                             
                            <div class="chat-item-avatar" style="background: @(isOwned ? "rgba(37, 211, 102, 0.1)" : "rgba(255, 77, 79, 0.1)"); display: flex; align-items: center; justify-content: center; border-radius: 12px; position: relative;">
                                <i class="@(svc.IconClass ?? "fas fa-star")" style="color: @(isOwned ? "#25d366" : "var(--accent-red)"); font-size: 18px;"></i>
                            </div>
                            
                            <div class="chat-item-details">
                                <div class="chat-item-name">@svc.Title</div>
                                <div class="chat-item-message" style="color: var(--text-secondary); font-size: 12.5px;">@svc.Description</div>
                            </div>
                            
                            <div class="chat-item-meta" onclick="event.stopPropagation();" style="display: flex; flex-direction: column; align-items: flex-end; gap: 4px;">
                                @if (isOwned)
                                {
                                    <span style="font-size: 10px; font-weight: 600; color: #25d366; background: rgba(37, 211, 102, 0.12); padding: 2px 8px; border-radius: 12px; border: 1px solid rgba(37, 211, 102, 0.2);">Active</span>
                                }
                                else
                                {
                                    <span style="font-weight: 700; font-size: 13.5px; color: var(--accent-red); margin-bottom: 2px;">$@svc.Price.ToString("0.00")</span>
                                    <div class="svc-checkbox" id="chk-box-@svc.Id" onclick="toggleCheckbox('@svc.Id')">
                                        <i class="fas fa-check" style="font-size: 10px; display: none;" id="chk-icon-@svc.Id"></i>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                }
            </div>
        </div>
    </div>

    <!-- Column 3 (Right Workspace Area) -->
    <div class="chat-workspace-panel">
        <!-- Default State: No service selected for purchase -->
        <div class="chat-welcome-state" id="emptyWorkspaceState">
            <div class="chat-welcome-icon">
                <i class="fas fa-cubes"></i>
            </div>
            <h3>HiChat Services</h3>
            <p>Upgrade your messaging workspace with real-time customizable options. Check services from the list to purchase and activate them instantly.</p>
            
            <div style="background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.05); padding: 18px 24px; border-radius: 16px; width: 100%; max-width: 400px; text-align: left; margin-bottom: 20px;">
                <div style="display: flex; gap: 12px; margin-bottom: 12px; align-items: center;">
                    <i class="fas fa-magic" style="color: var(--accent-red); font-size: 15px; width: 20px;"></i>
                    <span style="font-size: 13.5px; color: var(--text-secondary);">Real-time interface themes & styling</span>
                </div>
                <div style="display: flex; gap: 12px; margin-bottom: 12px; align-items: center;">
                    <i class="fas fa-palette" style="color: var(--accent-red); font-size: 15px; width: 20px;"></i>
                    <span style="font-size: 13.5px; color: var(--text-secondary);">Unlock customized bubble designs</span>
                </div>
                <div style="display: flex; gap: 12px; align-items: center;">
                    <i class="fas fa-check-circle" style="color: #25d366; font-size: 15px; width: 20px;"></i>
                    <span style="font-size: 13.5px; color: var(--text-secondary);">Instant activation with one-time payment</span>
                </div>
            </div>

            <div class="encryption-notice">
                <i class="fas fa-lock" style="color: #25d366;"></i> All transactions are protected via 256-bit SSL encryption
            </div>
        </div>

        <!-- Checkout Workspace State (Shows when selections exist) -->
        <div id="checkoutWorkspaceState" style="display: none; height: 100%; flex-direction: column;">
            <div class="chat-header">
                <div class="chat-header-user">
                    <div style="background: rgba(255, 77, 79, 0.1); width: 38px; height: 38px; border-radius: 50%; display: flex; align-items: center; justify-content: center;">
                        <i class="fas fa-shopping-cart" style="color: var(--accent-red); font-size: 16px;"></i>
                    </div>
                    <div>
                        <div class="chat-header-name">Secure Checkout</div>
                        <div class="chat-header-status">
                            <i class="fas fa-shield-alt" style="color: #25d366;"></i> Fully encrypted & secure
                        </div>
                    </div>
                </div>
            </div>

            <!-- Scrollable content -->
            <div style="flex: 1; overflow-y: auto; padding: 24px;">
                <div style="max-width: 520px; margin: 0 auto;">
                    <!-- Order Items summary -->
                    <div style="background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.05); border-radius: 20px; padding: 20px; margin-bottom: 20px;">
                        <h4 style="font-size: 11px; font-weight: 700; color: var(--text-muted); text-transform: uppercase; letter-spacing: 1.2px; margin-bottom: 16px; display: flex; align-items: center; gap: 8px;">
                            <i class="fas fa-receipt"></i> Selected Services
                        </h4>
                        <div id="checkoutItemsContainer">
                            <!-- Populated via javascript -->
                        </div>
                    </div>

                    <!-- Total amount bar -->
                    <div style="display: flex; justify-content: space-between; align-items: center; padding: 16px 20px; background: rgba(255,77,79,0.06); border: 1px solid rgba(255,77,79,0.15); border-radius: 16px; margin-bottom: 24px;">
                        <span style="color: var(--text-secondary); font-size: 14px; font-weight: 500;">Total to Pay:</span>
                        <strong id="checkoutTotalAmount" style="color: #fff; font-size: 24px; font-weight: 800;">$0.00</strong>
                    </div>

                    <!-- Card details mockup -->
                    <div style="background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.05); border-radius: 20px; padding: 20px; margin-bottom: 24px;">
                        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px;">
                            <h4 style="font-size: 11px; font-weight: 700; color: var(--text-muted); text-transform: uppercase; letter-spacing: 1.2px; display: flex; align-items: center; gap: 8px;">
                                <i class="fas fa-credit-card"></i> Credit Card Details
                            </h4>
                            <div style="display: flex; gap: 6px;">
                                <img src="https://upload.wikimedia.org/wikipedia/commons/thumb/2/2a/Mastercard-logo.svg/120px-Mastercard-logo.svg.png" style="height: 16px; opacity: 0.7;" alt="MC" />
                                <img src="https://upload.wikimedia.org/wikipedia/commons/thumb/5/5e/Visa_Inc._logo.svg/120px-Visa_Inc._logo.svg.png" style="height: 16px; opacity: 0.7;" alt="Visa" />
                            </div>
                        </div>

                        <!-- Card Fields -->
                        <div style="display: flex; flex-direction: column; gap: 12px;">
                            <div style="display: flex; align-items: center; background: rgba(0,0,0,0.2); border: 1px solid rgba(255,255,255,0.08); border-radius: 12px; padding: 0 16px; height: 48px;">
                                <i class="fas fa-credit-card" style="color: var(--text-muted); margin-right: 12px;"></i>
                                <input type="text" style="background: transparent; border: none; outline: none; color: #fff; font-size: 14px; width: 100%;" value="•••• •••• •••• 4242" readonly />
                            </div>
                            <div style="display: flex; gap: 12px;">
                                <div style="flex: 1; display: flex; align-items: center; background: rgba(0,0,0,0.2); border: 1px solid rgba(255,255,255,0.08); border-radius: 12px; padding: 0 16px; height: 48px;">
                                    <input type="text" style="background: transparent; border: none; outline: none; color: #fff; font-size: 14px; width: 100%; text-align: center;" value="12/28" readonly />
                                </div>
                                <div style="flex: 1; display: flex; align-items: center; background: rgba(0,0,0,0.2); border: 1px solid rgba(255,255,255,0.08); border-radius: 12px; padding: 0 16px; height: 48px;">
                                    <input type="password" style="background: transparent; border: none; outline: none; color: #fff; font-size: 14px; width: 100%; text-align: center;" value="123" readonly />
                                </div>
                            </div>
                            <div style="display: flex; align-items: center; background: rgba(0,0,0,0.2); border: 1px solid rgba(255,255,255,0.08); border-radius: 12px; padding: 0 16px; height: 48px;">
                                <i class="fas fa-user" style="color: var(--text-muted); margin-right: 12px;"></i>
                                <input type="text" style="background: transparent; border: none; outline: none; color: #fff; font-size: 14px; width: 100%;" value="@(User.Identity?.Name ?? "User")" readonly />
                            </div>
                        </div>
                    </div>

                    <!-- Payment Submit Button -->
                    <button class="pay-btn" id="checkoutPayBtn" onclick="submitRealPayment()" style="width: 100%; height: 50px; background: var(--accent-red); border: none; border-radius: 14px; color: #fff; font-size: 15px; font-weight: 700; cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 8px; box-shadow: 0 8px 24px rgba(255,77,79,0.3); transition: transform 0.2s;">
                        <i class="fas fa-lock"></i> Pay and Activate Services
                    </button>
                    
                    <div style="text-align: center; color: var(--text-muted); font-size: 12px; margin-top: 14px;">
                        <i class="fas fa-lock" style="color: #25d366; margin-right: 4px;"></i> Secure 256-bit encrypted connection.
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    let selectedIds = new Set();
    let servicePrices = {};
    let serviceTitles = {};
    let serviceIcons = {};

    // Populate service details from DOM
    document.querySelectorAll('.service-list-item:not(.owned)').forEach(el => {
        const id = el.dataset.id;
        servicePrices[id] = parseFloat(el.dataset.price);
        serviceTitles[id] = el.querySelector('.chat-item-name').innerText;
        serviceIcons[id] = el.querySelector('.chat-item-avatar i').className;
    });

    function toggleSelect(id) {
        const item = document.getElementById('svc-item-' + id);
        if (item.classList.contains('owned')) return;
        
        toggleCheckbox(id);
    }

    function toggleCheckbox(id) {
        const box = document.getElementById('chk-box-' + id);
        const icon = document.getElementById('chk-icon-' + id);
        const item = document.getElementById('svc-item-' + id);
        
        if (selectedIds.has(id)) {
            selectedIds.delete(id);
            item.classList.remove('selected');
            icon.style.display = 'none';
        } else {
            selectedIds.add(id);
            item.classList.add('selected');
            icon.style.display = '';
        }
        
        updateCheckoutPanel();
    }

    function updateCheckoutPanel() {
        const emptyState = document.getElementById('emptyWorkspaceState');
        const checkoutState = document.getElementById('checkoutWorkspaceState');
        const itemsContainer = document.getElementById('checkoutItemsContainer');
        const totalAmountEl = document.getElementById('checkoutTotalAmount');
        const payBtn = document.getElementById('checkoutPayBtn');
        
        if (selectedIds.size === 0) {
            emptyState.style.display = 'flex';
            checkoutState.style.display = 'none';
            return;
        }
        
        emptyState.style.display = 'none';
        checkoutState.style.display = 'flex';
        
        let html = '';
        let total = 0;
        
        selectedIds.forEach(id => {
            const title = serviceTitles[id];
            const price = servicePrices[id];
            const iconClass = serviceIcons[id];
            total += price;
            
            html += `
                <div style="display: flex; justify-content: space-between; align-items: center; padding: 12px 0; border-bottom: 1px solid rgba(255,255,255,0.03);">
                    <div style="display: flex; align-items: center; gap: 10px; color: var(--text-primary); font-size: 14px; font-weight: 500;">
                        <i class="${iconClass}" style="color: var(--accent-red); width: 16px;"></i>
                        <span>${title}</span>
                    </div>
                    <span style="font-weight: 700; color: var(--accent-red); font-size: 14px;">$${price.toFixed(2)}</span>
                </div>
            `;
        });
        
        itemsContainer.innerHTML = html;
        totalAmountEl.innerText = '$' + total.toFixed(2);
        payBtn.innerHTML = `<i class="fas fa-lock"></i> Pay $${total.toFixed(2)} & Activate`;
    }

    function submitRealPayment() {
        if (selectedIds.size === 0) return;
        const btn = document.getElementById('checkoutPayBtn');
        btn.disabled = true;
        btn.innerHTML = '<i class="fas fa-circle-notch fa-spin"></i> Processing Payment...';
        
        const idsString = Array.from(selectedIds).join(',');
        
        setTimeout(() => {
            btn.innerHTML = '<i class="fas fa-check-circle fa-spin"></i> Verifying details...';
            
            fetch('/Services/Pay', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: 'ids=' + encodeURIComponent(idsString)
            })
            .then(r => r.json())
            .then(data => {
                if (data.success) {
                    btn.style.background = '#25d366';
                    btn.innerHTML = '<i class="fas fa-check-circle" style="font-size: 18px;"></i> Payment Successful!';
                    Swal.fire({
                        title: 'Services Unlocked!',
                        text: 'Selected services are now active on your account!',
                        icon: 'success',
                        background: 'var(--bg-panel)',
                        color: 'var(--text-primary)',
                        confirmButtonColor: 'var(--accent-red)'
                    }).then(() => {
                        window.location.reload();
                    });
                } else {
                    btn.disabled = false;
                    btn.style.background = 'var(--accent-red)';
                    btn.innerHTML = '<i class="fas fa-lock"></i> Try Again';
                    Swal.fire({
                        title: 'Error',
                        text: data.message || 'Something went wrong.',
                        icon: 'error',
                        background: 'var(--bg-panel)',
                        color: 'var(--text-primary)',
                        confirmButtonColor: 'var(--accent-red)'
                    });
                }
            })
            .catch(() => {
                btn.disabled = false;
                btn.style.background = 'var(--accent-red)';
                btn.innerHTML = '<i class="fas fa-lock"></i> Try Again';
            });
        }, 2200);
    }

    function filterServices() {
        const query = document.getElementById('svcSearchInput').value.toLowerCase();
        const items = document.querySelectorAll('.service-list-item');
        
        items.forEach(item => {
            const title = item.dataset.title;
            const desc = item.dataset.desc;
            if (title.includes(query) || desc.includes(query)) {
                item.style.display = 'flex';
            } else {
                item.style.display = 'none';
            }
        });
    }

    function filterType(type, element) {
        document.querySelectorAll('.chat-filter-pill').forEach(el => el.classList.remove('active'));
        element.classList.add('active');
        
        const items = document.querySelectorAll('.service-list-item');
        items.forEach(item => {
            const owned = item.dataset.owned === 'true';
            if (type === 'all') {
                item.style.display = 'flex';
            } else if (type === 'active') {
                item.style.display = owned ? 'flex' : 'none';
            } else if (type === 'locked') {
                item.style.display = !owned ? 'flex' : 'none';
            }
        });
    }
</script>
}
