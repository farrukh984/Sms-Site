        function renderGroupContacts() {
            var container = document.getElementById('groupMembersListScrollable');
            container.innerHTML = '';
            
            var search = document.getElementById('groupMemberSearchInput').value.toLowerCase().trim();
            var filtered = allGroupContacts.filter(function(c) {
                var name = (c.fullName || '').toLowerCase();
                var nickname = (c.nickname || '').toLowerCase();
                return name.indexOf(search) > -1 || nickname.indexOf(search) > -1;
            });

            if (filtered.length === 0) {
                container.innerHTML = '<div style="text-align: center; color: var(--text-muted); padding: 15px; font-size: 13px;">No contacts found</div>';
                return;
            }

            // Sort contacts alphabetically by FullName
            filtered.sort(function(a, b) {
                return (a.fullName || '').localeCompare(b.fullName || '');
            });

            // Group by starting letter
            var groups = {};
            filtered.forEach(function(c) {
                var firstChar = (c.fullName || '').charAt(0).toUpperCase();
                if (!firstChar.match(/[A-Z]/)) {
                    firstChar = '#';
                }
                if (!groups[firstChar]) {
                    groups[firstChar] = [];
                }
                groups[firstChar].push(c);
            });

            // Sort keys so # comes first or last. Standard is # first, then A-Z.
            var keys = Object.keys(groups).sort();
            if (keys.indexOf('#') > -1) {
                // Move '#' to the beginning
                keys.splice(keys.indexOf('#'), 1);
                keys.unshift('#');
            }

            keys.forEach(function(letter) {
                var letterHtml = `
                    <div style="font-size: 13px; font-weight: 700; color: #25D366; padding: 15px 10px 5px; margin-bottom: 5px; border-bottom: 1px solid rgba(255,255,255,0.03);">${letter}</div>
                `;
                container.innerHTML += letterHtml;

                groups[letter].forEach(function(c) {
                    var isChecked = selectedGroupMemberIds.indexOf(c.id) > -1;
                    var activeClass = isChecked ? 'active-selection' : '';
                    var checkedAttr = isChecked ? 'checked' : '';
                    var currentBg = isChecked ? 'rgba(254, 76, 76, 0.1)' : 'transparent';
                    
                    var html = `
                        <div class="chat-item ${activeClass}" onclick="toggleGroupMemberSelection(${c.id}, this)" style="cursor: pointer; border-radius: 12px; margin-bottom: 5px; padding: 10px; background: ${currentBg};">
                            <div class="chat-item-avatar">
                                <img src="${c.profilePicture}" alt="Avatar" />
                            </div>
                            <div class="chat-item-details">
                                <div class="chat-item-name" style="font-size: 14px; color: white;">${c.fullName}</div>
                                <div style="font-size: 11px; color: var(--text-muted);">@@${c.nickname || 'user'}</div>
                            </div>
                            <div style="display: flex; align-items: center; padding-right: 5px;">
                                <input type="checkbox" class="group-member-checkbox" id="chk_member_${c.id}" ${checkedAttr} onclick="event.stopPropagation(); toggleGroupMemberSelection(${c.id}, this.closest('.chat-item'))" style="width: 18px; height: 18px; accent-color: var(--accent-red); cursor: pointer;" />
                            </div>
                        </div>
                    `;
                    container.innerHTML += html;
                });
            });
        }

