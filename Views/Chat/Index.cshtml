            var wrapper = e.target.closest('.message-wrapper[data-msgid]');
            if (wrapper && wrapper.classList.contains('select-mode')) {
                var msgId = parseInt(wrapper.getAttribute('data-msgid'));
                if (!isNaN(msgId)) {
                    toggleMsgSelection(e, msgId);
                }
