@using System.Security.Claims
@{
    ViewData["Title"] = "Chat Workspace";
    Layout = "~/Views/Shared/_Layout_Chat.cshtml";
    var currentUser = ViewBag.CurrentUser as Site.Models.Users;
}

<div class="chat-app-layout">
    <!-- Column 1 (Far Left Navigation Menu) -->
    @await Html.PartialAsync("_NavSidebar", "Chat")


    <!-- Column 2 (Middle Chats List) -->
    <div class="chat-list-panel" id="chatsListPanel">
        <!-- Panel A: Main Chats List -->
        <div id="chatsMainPanelContainer" style="display: flex; flex-direction: column; height: 100%;">
            <div class="chat-panel-header">
                <div class="chat-panel-title-bar">
                    <div style="display:flex; align-items:center; gap:12px;">
                        <div class="chat-item-avatar" style="width:36px; height:36px; border-radius:50%; overflow:hidden; background:var(--bg-main);">
                            <img src="@(!string.IsNullOrEmpty(currentUser?.ProfilePicture) ? currentUser.ProfilePicture : "/images/default-avatar.svg")" alt="Me" id="mobileHeaderAvatar" style="width:100%; height:100%; object-fit:cover;"/>
                        </div>
                        <h2>SMS SITE</h2>
                    </div>
                    <button class="neu-btn neu-btn-circle" onclick="openContactsModal_newChat()" style="width: 36px; height: 36px; font-size: 14px; display:flex; align-items:center; justify-content:center;" title="New SMS SITE"><i class="fas fa-edit" style="font-size:14px;"></i></button>
                </div>
                
                <div class="chat-search-container">
                    <input type="text" id="chatSearchInput" class="neu-input" placeholder="Search or start a new SMS SITE..." onkeyup="filterChatsList()" />
                </div>

                <div class="chat-filters">
                    <div class="chat-filter-pill active" onclick="setChatFilter('all', this)">All</div>
                    <div class="chat-filter-pill" onclick="setChatFilter('unread', this)">Unread</div>
                    <div class="chat-filter-pill" onclick="setChatFilter('groups', this)">Groups</div>
                </div>
            </div>

            <div class="chat-list-scrollable" id="chatsContainer">
                <!-- Loaded dynamically via JS -->
                <div style="text-align: center; color: var(--text-muted); margin-top: 40px; font-size: 14px;">Loading conversations...</div>
            </div>
        </div>

        <!-- Panel B: New Chat Selector Panel (Transitions from + button) -->
        <div id="newChatPanelContainer" style="display: none; flex-direction: column; height: 100%;">
            <div class="chat-panel-header" style="padding: 20px 20px 15px; border-bottom: 1px solid rgba(255,255,255,0.05); background: rgba(0,0,0,0.2);">
                <div style="display: flex; align-items: center; gap: 15px;">
                    <button class="neu-btn neu-btn-circle" onclick="backToChatsMain()" style="width:36px; height:36px; display:flex; align-items:center; justify-content:center; box-shadow:none; background:rgba(255,255,255,0.05); border:none;"><i class="fas fa-arrow-left" style="font-size: 14px; color: var(--text-secondary);"></i></button>
                    <h2 style="font-size: 18px; font-weight: 700; margin: 0; color: white;">New SMS SITE</h2>
                </div>
            </div>
            <div class="chat-search-container" style="padding: 15px 20px 5px;">
                <div style="position:relative;">
                    <i class="fas fa-search" style="position:absolute; left:16px; top:50%; transform:translateY(-50%); color:var(--text-muted); font-size:13px;"></i>
                    <input type="text" id="newChatSearchInput" class="neu-input" placeholder="Search name or number" onkeyup="filterNewChatList()" style="width:100%; padding-left:40px; border-radius:12px; background:rgba(255,255,255,0.02); border:1px solid rgba(255,255,255,0.05);" />
                </div>
            </div>
            <div class="chat-list-scrollable" id="newChatListScrollable" style="padding: 10px 12px;">
                <!-- Fixed Menu Options -->
                <div class="chat-item" onclick="openNewGroupWorkspace()" style="cursor: pointer;">
                    <div class="chat-item-avatar" style="background: rgba(255,255,255,0.02); display: flex; align-items: center; justify-content: center; box-shadow: var(--shadow-outset);">
                        <i class="fas fa-users" style="font-size: 18px; color: var(--accent-red);"></i>
                    </div>
                    <div class="chat-item-details">
                        <div class="chat-item-name" style="font-size: 14.5px;">New group</div>
                    </div>
                </div>

                <div class="chat-item" onclick="showNewContactForm()" style="cursor: pointer;">
                    <div class="chat-item-avatar" style="background: rgba(255,255,255,0.02); display: flex; align-items: center; justify-content: center; box-shadow: var(--shadow-outset);">
                        <i class="fas fa-user-plus" style="font-size: 18px; color: var(--accent-red);"></i>
                    </div>
                    <div class="chat-item-details">
                        <div class="chat-item-name" style="font-size: 14.5px;">New contact</div>
                    </div>
                </div>

                <div class="chat-item" onclick="window.location.href='/Community'" style="cursor: pointer;">
                    <div class="chat-item-avatar" style="background: rgba(255,255,255,0.02); display: flex; align-items: center; justify-content: center; box-shadow: var(--shadow-outset);">
                        <i class="fas fa-bullhorn" style="font-size: 18px; color: var(--accent-red);"></i>
                    </div>
                    <div class="chat-item-details">
                        <div class="chat-item-name" style="font-size: 14.5px;">New community</div>
                    </div>
                </div>

                <div style="font-size: 11px; text-transform: uppercase; color: var(--text-muted); font-weight: 600; padding: 20px 5px 8px; letter-spacing: 0.8px;">Contacts on HiChat</div>
                
                <div id="newChatContactsContainer">
                    <!-- Populated dynamically with registered users -->
                </div>
            </div>
        </div>

        <!-- Panel C: New Contact Form Panel -->
        <div id="newContactPanelContainer" style="display: none; flex-direction: column; height: 100%;">
            <div class="chat-panel-header" style="padding: 20px 20px 15px; border-bottom: 1px solid rgba(255,255,255,0.05); background: rgba(0,0,0,0.2);">
                <div style="display: flex; align-items: center; gap: 15px;">
                    <button class="neu-btn neu-btn-circle" onclick="backToNewChatSelector()" style="width:36px; height:36px; display:flex; align-items:center; justify-content:center; box-shadow:none; background:rgba(255,255,255,0.05); border:none;"><i class="fas fa-arrow-left" style="font-size: 14px; color: var(--text-secondary);"></i></button>
                    <h2 style="font-size: 18px; font-weight: 700; margin: 0; color: white;">New Contact</h2>
                </div>
            </div>
            <div class="chat-list-scrollable" style="padding: 25px 20px;">
                <div class="neu-input-group">
                    <label class="neu-input-label">First name</label>
                    <input type="text" id="newContactFirstName" class="neu-input" placeholder="First name" />
                </div>
                <div class="neu-input-group">
                    <label class="neu-input-label">Last name</label>
                    <input type="text" id="newContactLastName" class="neu-input" placeholder="Last name" />
                </div>
                <div class="neu-input-group">
                    <label class="neu-input-label">Contact number</label>
                    <input type="text" id="newContactPhone" class="neu-input" placeholder="Contact number" />
                </div>
                
                <div style="text-align: center; margin-top: 30px;">
                    <button class="neu-btn neu-btn-red" onclick="saveNewContact()" style="width: 100%; border-radius: 24px;">Save Contact</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Column 3 (Main Workspace - Chat Conversation or Welcome screen) -->
    <div class="chat-workspace-panel" id="chatWorkspacePanel" style="position: relative;">
        <!-- Default Welcome State -->
        <div class="chat-welcome-state" id="emptyChatState">
            <div class="chat-welcome-icon" style="width: 80px; height: 80px; border-radius: 24px; margin-bottom: 24px;">
                <svg viewBox="0 0 24 24" fill="none" stroke="var(--accent-red)" stroke-width="1.8" style="width: 40px; height: 40px;"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>
            </div>
            <h3 style="font-size: 26px; font-weight: 700; margin-bottom: 12px; font-family: 'Outfit', sans-serif;">Welcome to SMS SITE!</h3>
            <p style="font-size: 15px; color: var(--text-secondary); max-width: 440px; line-height: 1.6; margin-bottom: 24px;">Connect with your family and friends instantly. Select an existing conversation or start a new SMS SITE.</p>
            <button class="neu-btn neu-btn-red hover-lift" onclick="openContactsModal()" style="padding: 12px 28px; border-radius: 12px; font-weight: 700;">Start New SMS SITE</button>
        </div>

        <!-- Active Chat Window -->
        <div class="chat-workspace-panel" id="activeChatState" style="display: none; height: 100%;">
            <!-- Chat Header -->
            <div class="chat-header">
                <div class="chat-header-user" onclick="toggleDetailsDrawer()">
                    <button class="d-md-none" onclick="goBackToChatsList(event)" style="margin: 0; padding: 0; width: 30px; height: 30px; display: flex; align-items: center; justify-content: center; background: transparent; border: none; flex-shrink: 0;"><i class="fas fa-arrow-left" style="font-size:16px; color: var(--accent-red);"></i></button>
                    <div class="chat-item-avatar" style="overflow: hidden; border-radius: 50%; display: flex; align-items: center; justify-content: center; background: rgba(255,255,255,0.05); flex-shrink: 0;">
                        <img src="/images/default-avatar.svg" id="activeChatAvatar" alt="Avatar" style="width: 100%; height: 100%; object-fit: cover;" />
                    </div>
                    <div style="min-width: 0; flex: 1;">
                        <div class="chat-header-name" id="activeChatName" style="white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">Loading...</div>
                        <div class="chat-header-status" id="activeChatStatus" style="display:none; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; opacity: 0.7;"></div>
                    </div>
                </div>
                <div class="chat-header-actions">
                    <button class="neu-btn neu-btn-circle hover-glow" onclick="startCall('audio')" style="width: 40px; height: 40px; display: flex; align-items: center; justify-content: center;" title="Audio Call"><i class="fas fa-phone" style="font-size: 14px;"></i></button>
                    <button class="neu-btn neu-btn-circle hover-glow" onclick="startCall('video')" style="width: 40px; height: 40px; display: flex; align-items: center; justify-content: center;" title="Video Call"><i class="fas fa-video" style="font-size: 14px;"></i></button>
                    <button class="neu-btn neu-btn-circle hover-glow" onclick="toggleHeaderMenu()" style="width: 40px; height: 40px; display: flex; align-items: center; justify-content: center;" title="More options"><i class="fas fa-ellipsis-v" style="font-size: 14px;"></i></button>
                    
                    <!-- Header Dropdown Menu -->
                    <div class="header-dropdown-menu" id="headerDropdownMenu" style="display: none;">
                        <div class="header-dropdown-item" onclick="searchMessages()">
                            <i class="fas fa-search"></i>
                            <span>Search Message</span>
                        </div>
                        <div class="header-dropdown-item" onclick="toggleMuteChat()">
                            <i class="fas fa-bell-slash"></i>
                            <span>Mute Notifications</span>
                        </div>
                        <div class="header-dropdown-item" onclick="clearChatHistory()">
                            <i class="fas fa-trash-alt"></i>
                            <span>Clear SMS SITE</span>
                        </div>
                        <div class="header-dropdown-separator"></div>
                        <div class="header-dropdown-item danger-option" onclick="blockCurrentContact()">
                            <i class="fas fa-ban"></i>
                            <span>Block User</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Not a Contact Banner -->
            <div id="notAContactBanner" style="display:none; background: var(--bg-main); padding: 16px; margin: 15px 20px 0; border-radius: 12px; border: 1px solid rgba(255,255,255,0.05); text-align: center; z-index: 5;">
                <div style="font-size: 13px; color: var(--text-muted); margin-bottom: 12px;" id="notAContactText">
                    Not a contact
                </div>
                <div style="color: #25D366; font-size: 13px; margin-bottom: 16px; display:flex; align-items:center; justify-content:center; gap: 6px;">
                    <i class="fas fa-shield-alt"></i> Safety tools
                </div>
                <div style="display: flex; gap: 10px; justify-content: center;">
                    <button class="neu-btn" style="flex:1; max-width: 150px; background: rgba(254,76,76,0.1); color: var(--accent-red); border: 1px solid rgba(254,76,76,0.3); border-radius: 20px; box-shadow: none;" onclick="blockCurrentContact()"><i class="fas fa-ban" style="margin-right:6px;"></i> Block</button>
                    <button class="neu-btn" style="flex:1; max-width: 150px; background: rgba(37,211,102,0.1); color: #25D366; border: 1px solid rgba(37,211,102,0.3); border-radius: 20px; box-shadow: none;" onclick="showAddContactFromBanner()"><i class="fas fa-user-plus" style="margin-right:6px;"></i> Add</button>
                </div>
            </div>

            <!-- Chat Message Feed -->
            <div class="chat-message-feed" id="messagesFeed">
                <!-- Loaded dynamically via JS -->
            </div>

            <!-- Chat Input Bar -->
            <div class="chat-input-bar">
                <!-- Reply Preview Box -->
                <div id="replyPreviewBox" style="display:none; background:rgba(20,21,26,0.85); border-left:4px solid var(--accent-red); padding:8px 14px 8px 12px; margin:0 10px 8px 10px; border-radius:10px; position:relative; flex-shrink:0; backdrop-filter:blur(10px);">
                    <div style="font-size:11px; font-weight:700; color:var(--accent-red); margin-bottom:4px;" id="replyPreviewName">You</div>
                    <div id="replyPreviewContent" style="display:flex; align-items:center; gap:6px; font-size:13px; color:rgba(255,255,255,0.6); white-space:nowrap; overflow:hidden; text-overflow:ellipsis; max-width:90%;"></div>
                    <i class="fas fa-times" onclick="cancelReply()" style="position:absolute; top:10px; right:12px; color:rgba(255,255,255,0.4); cursor:pointer; font-size:13px;"></i>
                </div>
                <!-- Attachments overlay -->
                <div class="attachment-sheet" id="attachmentSheet" style="display: none;">
                    <div class="attachment-sheet-item" onclick="triggerFileUpload('Document')">
                        <div class="attachment-icon-circle" style="background: #5f6368; display: flex; align-items: center; justify-content: center;"><i class="fas fa-file-alt" style="font-size: 16px; color: white;"></i></div>
                        <span class="attachment-sheet-label">Document</span>
                    </div>
                    <div class="attachment-sheet-item" onclick="triggerCameraCapture()">
                        <div class="attachment-icon-circle" style="background: #e53935; display: flex; align-items: center; justify-content: center;"><i class="fas fa-camera" style="font-size: 16px; color: white;"></i></div>
                        <span class="attachment-sheet-label">Camera</span>
                    </div>
                    <div class="attachment-sheet-item" onclick="triggerFileUpload('Image')">
                        <div class="attachment-icon-circle" style="background: #1e88e5; display: flex; align-items: center; justify-content: center;"><i class="fas fa-image" style="font-size: 16px; color: white;"></i></div>
                        <span class="attachment-sheet-label">Gallery</span>
                    </div>
                </div>

                <input type="file" id="messageFileInput" style="display: none;" onchange="uploadSelectedFile()" />

                <!-- Text / Voice Input elements & Send button wrapper -->
                <div style="display: flex; align-items: center; gap: 15px; width: 100%;">
                    <div class="chat-input-container" style="background: #1b1d22 !important; border: 1px solid transparent !important; box-shadow: inset 4px 4px 10px #131418, inset -4px -4px 10px #23262c !important; border-radius: 30px;">
                        <button class="chat-input-action-btn" onclick="toggleEmojiPicker()" title="Emoji"><i class="far fa-smile" style="color: var(--accent-red); font-size: 18px;"></i></button>
                        <input type="text" id="chatMessageInput" class="chat-input-box" placeholder="Type a message" oninput="handleTyping()" onkeydown="handleInputKeydown(event)" />
                        <button class="chat-input-action-btn" onclick="toggleAttachmentSheet()" title="Attach file"><i class="fas fa-paperclip" style="color: var(--accent-red); font-size: 18px;"></i></button>
                        <button class="chat-input-action-btn d-none d-md-flex" title="Camera"><i class="fas fa-camera" style="color: var(--accent-red); font-size: 18px;"></i></button>
                    </div>

                    <!-- Microphone/Send Toggle Button -->
                    <button class="neu-btn neu-btn-circle active" id="sendOrMicBtn" onclick="sendOrRecord()" style="width: 50px; height: 50px; background: var(--accent-red); color: white; display: flex; align-items: center; justify-content: center; flex-shrink: 0;" title="Send or Record">
                        <i id="sendOrMicIcon" class="fas fa-microphone" style="font-size: 16px;"></i>
                    </button>
                </div>
            </div>
        </div>

        <!-- Add Group Members Overlay -->
        <div id="newGroupPanelContainer" style="display: none; flex-direction: column; height: 100%; width: 100%; position: absolute; top: 0; left: 0; background: var(--bg-main); z-index: 10;">
            <div class="chat-panel-header" style="padding: 20px 20px 15px; border-bottom: 1px solid rgba(255,255,255,0.05); background: rgba(0,0,0,0.2);">
                <div style="display: flex; align-items: center; justify-content: space-between; width: 100%;">
                    <div style="display: flex; align-items: center; gap: 15px;">
                        <button class="neu-btn neu-btn-circle" onclick="backToChatsMainFromGroup()" style="width:36px; height:36px; display:flex; align-items:center; justify-content:center; box-shadow:none; background:rgba(255,255,255,0.05); border:none;"><i class="fas fa-arrow-left" style="font-size: 14px; color: var(--text-secondary);"></i></button>
                        <div>
                            <h2 style="font-size: 18px; font-weight: 700; margin: 0; color: white;">Add Group Members</h2>
                            <div style="font-size: 12px; color: var(--accent-red); font-weight: 500;" id="groupSelectedCount">0 members selected</div>
                        </div>
                    </div>
                    <button class="neu-btn neu-btn-red" id="groupNextBtn" onclick="showGroupNameSetup()" style="border-radius: 24px; padding: 8px 20px; font-size: 13px; font-weight: 600; display: none; box-shadow: 0 4px 12px rgba(254, 76, 76, 0.3);">Next <i class="fas fa-arrow-right" style="margin-left:6px;"></i></button>
                </div>
            </div>
            <div class="chat-search-container" style="padding: 15px 20px 5px;">
                <div style="position:relative;">
                    <i class="fas fa-search" style="position:absolute; left:16px; top:50%; transform:translateY(-50%); color:var(--text-muted); font-size:13px;"></i>
                    <input type="text" id="groupMemberSearchInput" class="neu-input" placeholder="Search name or number" onkeyup="filterGroupMemberList()" style="width:100%; padding-left:40px; border-radius:12px; background:rgba(255,255,255,0.02); border:1px solid rgba(255,255,255,0.05);" />
                </div>
            </div>
            <div class="chat-list-scrollable" id="groupMembersListScrollable" style="padding: 10px 12px; flex: 1; overflow-y: auto;">
                <!-- Sorted & Grouped members loaded via JS -->
            </div>
        </div>

        <!-- Group Name Setup Overlay -->
        <div id="groupNamePanelContainer" style="display: none; flex-direction: column; height: 100%; width: 100%; position: absolute; top: 0; left: 0; background: var(--bg-main); z-index: 10;">
            <div class="chat-panel-header" style="padding: 20px 20px 15px; border-bottom: 1px solid rgba(255,255,255,0.05); background: rgba(0,0,0,0.2);">
                <div style="display: flex; align-items: center; gap: 15px;">
                    <button class="neu-btn neu-btn-circle" onclick="backToGroupMembers()" style="width:36px; height:36px; display:flex; align-items:center; justify-content:center; box-shadow:none; background:rgba(255,255,255,0.05); border:none;"><i class="fas fa-arrow-left" style="font-size: 14px; color: var(--text-secondary);"></i></button>
                    <h2 style="font-size: 18px; font-weight: 700; margin: 0; color: white;">Setup New Group</h2>
                </div>
            </div>
            <div style="flex: 1; overflow-y: auto; padding: 40px 25px;">
                <!-- Group Picture Upload -->
                <div style="display: flex; flex-direction: column; align-items: center; margin-bottom: 35px;">
                    <div id="groupAvatarPreviewWrap" style="width: 100px; height: 100px; border-radius: 50%; background: rgba(255,255,255,0.03); display: flex; align-items: center; justify-content: center; box-shadow: 0 8px 24px rgba(0,0,0,0.2); border: 2px dashed rgba(255,255,255,0.1); margin-bottom: 15px; cursor: pointer; position: relative; overflow: hidden; transition: all 0.2s;" onmouseover="this.style.background='rgba(255,255,255,0.06)'" onmouseout="this.style.background='rgba(255,255,255,0.03)'" onclick="document.getElementById('groupPictureFileInput').click()" title="Click to add group photo">
                        <img id="groupAvatarPreviewImg" src="" alt="" style="display:none; width:100%; height:100%; object-fit:cover; border-radius:50%;" />
                        <i id="groupAvatarPlaceholderIcon" class="fas fa-camera" style="font-size: 32px; color: var(--text-muted);"></i>
                        <div style="position:absolute; bottom:0; background: rgba(37,211,102,0.85); width:100%; text-align:center; font-size:10px; padding: 3px 0; color:white;">Add Photo</div>
                    </div>
                    <input type="file" id="groupPictureFileInput" accept="image/*" style="display:none;" onchange="previewGroupPicture(event)" />
                    <div style="font-size: 12px; color: var(--text-muted); text-align: center;">Optional: Add a group photo</div>
                </div>

                <div class="neu-input-group">
                    <label class="neu-input-label">Group Subject / Name</label>
                    <input type="text" id="newGroupName" class="neu-input" placeholder="Enter group name..." maxlength="25" />
                </div>

                <div style="text-align: center; margin-top: 40px;">
                    <button class="neu-btn neu-btn-red" onclick="createGroupConfirm()" style="width: 100%; border-radius: 24px; padding: 14px;">Create Group</button>
                </div>
            </div>
        </div>

    </div>

    <!-- Column 4 (Far Right Profile Drawer) -->
    <div class="detail-drawer" id="detailsDrawer" style="display: none;">
        <div class="drawer-header" style="background: rgba(0,0,0,0.2); border-bottom: 1px solid rgba(255,255,255,0.05); padding: 18px 20px;">
            <h4 style="font-size: 16px; font-weight: 700; color: white; margin: 0;">Contact Info</h4>
            <button class="neu-btn neu-btn-circle" onclick="toggleDetailsDrawer()" style="width: 32px; height: 32px; display:flex; align-items:center; justify-content:center; box-shadow:none; background:rgba(255,255,255,0.05); border:none;"><i class="fas fa-times" style="font-size:13px; color:var(--text-secondary);"></i></button>
        </div>
        <div class="drawer-content">
            <div class="drawer-profile-info">
                <div class="drawer-avatar">
                    <img src="/images/default-avatar.svg" id="drawerAvatar" alt="Profile" />
                </div>
                <div class="drawer-title" id="drawerFullName"></div>
                <div class="drawer-subtitle" id="drawerNickname"></div>
            </div>

            <!-- Single User Section -->
            <div id="drawerSingleUserSection">
                <div class="drawer-section-title" style="font-size: 11px; text-transform: uppercase; letter-spacing: 1px; color: var(--text-muted); margin-bottom: 10px;">Contact Details</div>
                <div style="background: rgba(255,255,255,0.02); border-radius: 16px; padding: 15px; margin-bottom: 20px; border: 1px solid rgba(255,255,255,0.03);">
                    <div class="drawer-option-row" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px;">
                        <span class="row-label" style="display: flex; align-items: center; color: var(--text-secondary); font-size: 13px;"><i class="fas fa-envelope" style="width: 24px; color: var(--text-muted); font-size: 14px;"></i> Email</span>
                        <span id="drawerEmail" style="font-weight: 600; font-size: 13px; color: white;"></span>
                    </div>
                    <div style="height: 1px; background: rgba(255,255,255,0.05); margin-bottom: 12px;"></div>
                    <div class="drawer-option-row" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px;">
                        <span class="row-label" style="display: flex; align-items: center; color: var(--text-secondary); font-size: 13px;"><i class="fas fa-phone" style="width: 24px; color: var(--accent-red); font-size: 14px;"></i> Mobile</span>
