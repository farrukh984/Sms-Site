    <!-- More Options Bottom Sheet -->
    <div id="callOptionsSheet">
      <div class="sheet-handle"></div>
      <div class="sheet-enc"><i class="fas fa-lock" style="margin-right:5px;"></i>End-to-end encrypted</div>
      <div class="sheet-item" onclick="shareScreen()">
        <span>Share screen</span>
        <i class="fas fa-mobile-alt"></i>
      </div>
      <div class="sheet-item" onclick="sendMessageFromCall()">
        <span>Send message</span>
        <i class="far fa-comment-alt"></i>
      </div>
    </div>

  </div>
</div>


