                        showToast('<i class="fas fa-share" style="margin-right:8px;"></i>Forwarded successfully', 'success');
                        closeForwardModal();
                        if (_isSelectModeActive) exitSelectMode();

                        if (res.broadcastData) {
                            res.broadcastData.forEach(function(b) {
                                console.log('[Forward] Broadcasting:', b.chatId, b.type, b.fileUrl, b.content);
                                connection.invoke("SendMessage", b.chatId.toString(), currentUserId.toString(), currentUserFullName, b.content, b.type, b.fileUrl || null, b.messageId, null, null);
