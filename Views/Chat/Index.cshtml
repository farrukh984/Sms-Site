                if (senderLabelEl) senderDisplayName = senderLabelEl.textContent.trim();
            }

            var previewEl = document.getElementById('replyPreviewContent');
            
            if (msgData.type === 'Audio') {
                var durText = '0:00';
                if (wrapper) {
                    var timeEl = wrapper.querySelector('.wa-vp-time');
                    if (timeEl) durText = timeEl.textContent.trim();
                }
                // Embed sender name so render can show it: "ðŸŽ¤[Farooq] 0:24"
                replyContent = '\uD83C\uDFA4[' + senderDisplayName + '] ' + durText;
                activeContextMsgContent = replyContent;
                previewEl.innerHTML = '<i class="fas fa-microphone" style="color:var(--accent-red); font-size:12px;"></i><span>' + durText + '</span>';
            } else if (msgData.type === 'Image') {
