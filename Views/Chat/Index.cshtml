        function toggleMsgSelection(event, msgId) {
            if (event) { event.stopPropagation(); event.preventDefault(); }
            var wrapper = document.querySelector('.message-wrapper[data-msgid="'+msgId+'"]');
            if (!wrapper) return;
            
            var idx = selectedMessageIds.indexOf(msgId);
            if (idx > -1) {
                selectedMessageIds.splice(idx, 1);
                wrapper.classList.remove('msg-selected');
            } else {
                selectedMessageIds.push(msgId);
                wrapper.classList.add('msg-selected');
            }
            updateSelectCount();
