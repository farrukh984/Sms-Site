    padding: 12px 22px 38px 22px;
    transform: translateY(100%);
    transition: transform 0.28s cubic-bezier(0.4,0,0.2,1);
    box-shadow: 0 -4px 30px rgba(0,0,0,0.6);
  }
  .sheet-handle { width: 36px; height: 4px; background: rgba(255,255,255,0.18); border-radius: 2px; margin: 0 auto 16px; }
  .sheet-enc { text-align:center; color:rgba(255,255,255,0.38); font-size:12px; margin-bottom:14px; letter-spacing:0.3px; }
  .sheet-item {
    display: flex; justify-content: space-between; align-items: center;
    padding: 15px 0; cursor: pointer;
    border-bottom: 1px solid rgba(255,255,255,0.06);
    transition: opacity 0.15s;
  }
  .sheet-item:last-child { border-bottom: none; }
  .sheet-item:hover { opacity: 0.72; }
  .sheet-item span { color: #fff; font-size: 16px; font-weight: 500; }
  .sheet-item i { color: rgba(255,255,255,0.65); font-size: 18px; }

  /* DESKTOP: show as centered card */
  @@media (min-width: 768px) {
    #callOverlay {
      display: none;
      align-items: center;
      justify-content: center;
      background: rgba(0,0,0,0.82);
    }
    #callInnerPanel {
      width: 370px;
      height: 680px;
      border-radius: 26px;
      overflow: hidden;
      box-shadow: 0 30px 80px rgba(0,0,0,0.85);
    }
    #callHeader { padding-top: 36px; }
  }
</style>

<div id="callOverlay">
  <div id="callInnerPanel">

    <!-- Header -->
    <div id="callHeader">
