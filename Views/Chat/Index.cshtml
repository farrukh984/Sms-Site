        // â”€â”€ Delete Flow â”€â”€
        function showDeleteDialog() {
            document.getElementById('messageContextMenu').style.display = 'none';
            if (!activeContextMsgId) return;
            _pendingDeleteMsgIds = [activeContextMsgId];
            
            var wrapper = document.querySelector('.message-wrapper[data-msgid="'+activeContextMsgId+'"]');
            var canDeleteEveryone = wrapper && wrapper.classList.contains('outgoing');

            var modal = document.getElementById('deleteConfirmModal');
            modal.querySelector('.wa-delete-btn-everyone').style.display = canDeleteEveryone ? 'block' : 'none';
            modal.querySelector('.wa-delete-modal-title').textContent = 'Delete message?';
