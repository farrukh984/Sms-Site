                    video: true, 
                    audio: {
                        echoCancellation: true,
                        noiseSuppression: true,
                        autoGainControl: true
                    } 
                }).then(function(stream) {
                    callStream = stream;
                    document.getElementById("callLocalVideo").srcObject = stream;
                }).catch(function(err) {
