        function showDeleteDialogForSelected() {
            if (selectedMessageIds.length === 0) {
                showToast('No messages selected', 'error');
                return;
            }
            _pendingDeleteMsgIds = [...selectedMessageIds];
            
            var canDeleteEveryone = true;
            for (var i = 0; i < _pendingDeleteMsgIds.length; i++) {
                var wrapper = document.querySelector('.message-wrapper[data-msgid="'+_pendingDeleteMsgIds[i]+'"]');
                if (!wrapper || !wrapper.classList.contains('outgoing')) {
                    canDeleteEveryone = false;
                    break;
                }
            }

            var modal = document.getElementById('deleteConfirmModal');
            modal.querySelector('.wa-delete-btn-everyone').style.display = canDeleteEveryone ? 'block' : 'none';
            var count = _pendingDeleteMsgIds.length;
            modal.querySelector('.wa-delete-modal-title').textContent = 'Delete ' + count + ' message' + (count > 1 ? 's' : '') + '?';
            modal.style.display = 'flex';
        }

        function closeDeleteDialog() {
            document.getElementById('deleteConfirmModal').style.display = 'none';
            _pendingDeleteMsgIds = [];
        }

        function confirmDeleteForEveryone() {
            var idsToDelete = [..._pendingDeleteMsgIds];
            closeDeleteDialog();
            idsToDelete.forEach(function(msgId) {
                $.post("/Chat/DeleteMessage", { messageId: msgId }, function(res) {
                    if (res.success) {
                        connection.invoke("BroadcastDelete", activeChatId.toString(), msgId);
                    }
                });
            });
            if (_isSelectModeActive) exitSelectMode();
            showToast('<i class="fas fa-trash-alt" style="margin-right:8px;"></i>Deleted for everyone', 'success');
        }

        function confirmDeleteForMe() {
            var idsToDelete = [..._pendingDeleteMsgIds];
            closeDeleteDialog();
            
            var locallyDeleted = [];
            try { locallyDeleted = JSON.parse(localStorage.getItem('deletedMessages_forMe') || '[]'); } catch(e) {}

            idsToDelete.forEach(function(msgId) {
                if (!locallyDeleted.includes(msgId)) {
                    locallyDeleted.push(msgId);
                }
                var wrapper = document.querySelector('.message-wrapper[data-msgid="'+msgId+'"]');
                if (wrapper) {
                    wrapper.style.transition = 'all 0.3s ease';
                    wrapper.style.opacity = '0';
                    wrapper.style.transform = 'scale(0.8)';
                    setTimeout(function() { wrapper.remove(); }, 300);
                }
            });
            
            localStorage.setItem('deletedMessages_forMe', JSON.stringify(locallyDeleted));

            if (_isSelectModeActive) exitSelectMode();
            showToast('<i class="fas fa-trash-alt" style="margin-right:8px;"></i>Deleted for me', 'success');
        }

