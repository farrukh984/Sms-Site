                    } else {
                        backToNewChatSelector();
                        // Reload contacts list in the background
                        if (typeof loadNewChatContacts === 'function') loadNewChatContacts();
                        if (res.targetUserId) {
                            startNewChat(res.targetUserId, res.name, res.avatar);
                        }
                    }
                } else {
                    Swal.fire({ text: res.message, icon: 'error', confirmButtonColor: '#25D366', background: 'var(--bg-panel)', color: 'var(--text-main)', customClass: { popup: 'rounded-4 border border-secondary shadow-lg' } });
