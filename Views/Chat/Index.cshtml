                        document.getElementById('emptyChatState').style.display = 'none';
                        // Reset picture preview
                        document.getElementById('groupAvatarPreviewImg').style.display = 'none';
                        document.getElementById('groupAvatarPlaceholderIcon').style.display = 'block';
                        document.getElementById('groupPictureFileInput').value = '';

                        loadChatsList();
                        backToChatsMain();

                        var avatar = res.groupPicture || '/images/group-avatar.png';
                        openConversation(res.chatId, res.chatName, avatar, null, true);
                    } else {
                        alert(res.message);
                    }
                },
                error: function() {
                    alert('An error occurred while creating the group.');
                }
            });
        }

        // ======== Group Picture Preview (during creation) ========
        function previewGroupPicture(event) {
            var file = event.target.files[0];
            if (!file) return;
            var reader = new FileReader();
            reader.onload = function(e) {
                var img = document.getElementById('groupAvatarPreviewImg');
                var icon = document.getElementById('groupAvatarPlaceholderIcon');
                img.src = e.target.result;
                img.style.display = 'block';
                icon.style.display = 'none';
            };
            reader.readAsDataURL(file);
        }

        // ======== Admin: Upload Group Photo from Drawer ========
        function uploadGroupPhoto(event) {
            var file = event.target.files[0];
            if (!file || !activeChatId) return;

            var formData = new FormData();
            formData.append('chatId', activeChatId);
            formData.append('groupPicture', file);

            $.ajax({
                url: '/Chat/UpdateGroupDetails',
                type: 'POST',
                data: formData,
                processData: false,
                contentType: false,
                success: function(res) {
                    if (res.success) {
                        var newUrl = res.groupPicture || '/images/group-avatar.png';
                        document.getElementById('drawerAvatar').src = newUrl;
                        document.getElementById('activeChatAvatar').src = newUrl;
                        loadChatsList();
                    } else {
                        alert(res.message || 'Failed to update group photo.');
                    }
                },
                error: function() { alert('Error uploading group photo.'); }
            });
            // Reset file input so same file can be re-selected
            event.target.value = '';
        }

        // ======== Admin: Toggle Admin Status ========
        function toggleMemberAdmin(chatId, targetUserId, btn) {
            $.post('/Chat/ToggleAdminStatus', { chatId: chatId, targetUserId: targetUserId }, function(res) {
                if (res.success) {
                    btn.textContent = res.isAdmin ? 'Remove Admin' : 'Make Admin';
                    // Refresh group info to update badges
                    var name = document.getElementById('activeChatName').textContent;
                    var avatar = document.getElementById('activeChatAvatar').src;
                    // Reload group info section
                    $.get('/Chat/GetGroupInfo?chatId=' + chatId, function(info) {
                        activeGroupInfo = info;
                        renderGroupInfo(info);
                    });
                } else {
                    alert(res.message || 'Could not update admin status.');
                }
            });
        }

        // ======== Admin: Remove Group Member ========
        function removeGroupMember(chatId, targetUserId, btn) {
            if (!confirm('Are you sure you want to remove this member from the group?')) return;
            
            // disable button
            var originalHtml = btn.innerHTML;
            btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i>';
            btn.disabled = true;

            $.post('/Chat/RemoveGroupMember', { chatId: chatId, targetUserId: targetUserId }, function(res) {
                if (res.success) {
                    // Re-fetch group info to update the list and member count
                    $.get('/Chat/GetGroupInfo?chatId=' + chatId, function(info) {
                        activeGroupInfo = info;
                        renderGroupInfo(info);
                    });
                } else {
                    btn.innerHTML = originalHtml;
                    btn.disabled = false;
                    alert(res.message || 'Could not remove member.');
                }
            });
        }

        // ======== Admin: Edit Group Name ========
        function openEditGroupNameModal() {
            var currentName = document.getElementById('activeChatName').textContent;
            document.getElementById('editGroupNameInput').value = currentName;
            document.getElementById('editGroupNameModal').style.display = 'flex';
        }

        function saveGroupName() {
            var newName = document.getElementById('editGroupNameInput').value.trim();
            if (!newName) { alert('Group name cannot be empty.'); return; }
            if (!activeChatId) return;

            $.post('/Chat/UpdateGroupDetails', { chatId: activeChatId, groupName: newName }, function(res) {
                if (res.success) {
                    document.getElementById('activeChatName').textContent = res.chatName;
                    document.getElementById('drawerFullName').textContent = res.chatName;
                    document.getElementById('editGroupNameModal').style.display = 'none';
                    loadChatsList();
                } else {
                    alert(res.message || 'Failed to update group name.');
                }
            });
        }

        // ======== Admin: Add Members to Existing Group ========
        var addMemberSelectedIds = [];
        var addMemberAllContacts = [];
        var addMemberExistingIds = [];

        function openAddGroupMembersPanel() {
            addMemberSelectedIds = [];
            addMemberAllContacts = [];
            addMemberExistingIds = [];
            document.getElementById('addMemberSearchInput').value = '';
            document.getElementById('addMemberSelectedCount').textContent = '0 selected';

            // Load current group members to exclude them
            $.get('/Chat/GetGroupInfo?chatId=' + activeChatId, function(groupInfo) {
                addMemberExistingIds = groupInfo.members.map(function(m) { return m.id; });

                $.get('/Chat/GetContacts', function(contacts) {
                    // Filter out existing members
                    addMemberAllContacts = contacts.filter(function(c) {
                        return addMemberExistingIds.indexOf(c.id) === -1;
                    });
                    renderAddMemberList();
                    document.getElementById('addGroupMembersModal').style.display = 'flex';
                });
            });
        }

        function renderAddMemberList() {
            var search = document.getElementById('addMemberSearchInput').value.toLowerCase();
            var container = document.getElementById('addMemberContactsList');
            container.innerHTML = '';

            var filtered = addMemberAllContacts.filter(function(c) {
                return (c.fullName || '').toLowerCase().indexOf(search) > -1;
            });

            if (filtered.length === 0) {
                container.innerHTML = '<div style="text-align:center; color:var(--text-muted); padding:20px; font-size:13px;">No contacts to add</div>';
                return;
            }

            filtered.forEach(function(c) {
                var isSelected = addMemberSelectedIds.indexOf(c.id) > -1;
                var bg = isSelected ? 'rgba(254,76,76,0.1)' : 'rgba(255,255,255,0.02)';
                container.innerHTML += `
                    <div onclick="toggleAddMemberSelection(${c.id}, this)" style="display:flex; align-items:center; gap:10px; padding:10px 12px; border-radius:10px; cursor:pointer; background:${bg}; transition: background 0.2s;">
                        <div style="width:38px; height:38px; border-radius:50%; overflow:hidden; flex-shrink:0;">
                            <img src="${c.profilePicture}" alt="Avatar" style="width:100%; height:100%; object-fit:cover;" />
                        </div>
                        <div style="flex:1; font-size:14px; font-weight:500; color:white;">${c.fullName}</div>
                        <input type="checkbox" ${isSelected ? 'checked' : ''} onclick="event.stopPropagation(); toggleAddMemberSelection(${c.id}, this.closest('div[onclick]'))" style="width:17px; height:17px; accent-color:var(--accent-red); cursor:pointer; pointer-events:none;" />
                    </div>`;
            });
        }

        function filterAddMemberList() {
            renderAddMemberList();
        }

        function toggleAddMemberSelection(userId, el) {
            var idx = addMemberSelectedIds.indexOf(userId);
            if (idx > -1) {
                addMemberSelectedIds.splice(idx, 1);
                el.style.background = 'rgba(255,255,255,0.02)';
                var cb = el.querySelector('input[type=checkbox]');
                if (cb) cb.checked = false;
            } else {
                addMemberSelectedIds.push(userId);
                el.style.background = 'rgba(254,76,76,0.1)';
                var cb = el.querySelector('input[type=checkbox]');
                if (cb) cb.checked = true;
            }
            var n = addMemberSelectedIds.length;
            document.getElementById('addMemberSelectedCount').textContent = n + ' selected';
        }

        function confirmAddGroupMembers() {
            if (addMemberSelectedIds.length === 0) {
                alert('Please select at least one member to add.');
                return;
            }

            $.ajax({
                url: '/Chat/AddGroupMembers',
                type: 'POST',
                data: { chatId: activeChatId, memberIds: addMemberSelectedIds },
                success: function(res) {
                    if (res.success) {
                        document.getElementById('addGroupMembersModal').style.display = 'none';
                        // Refresh group info in drawer
                        var name = document.getElementById('activeChatName').textContent;
                        var avatar = document.getElementById('activeChatAvatar').src;
                        openConversation(activeChatId, name, avatar, null, true);
                        // Show drawer again
                        document.getElementById('detailsDrawer').style.display = 'flex';
                    } else {
                        alert(res.message || 'Failed to add members.');
                    }
                },
                error: function() { alert('Error adding group members.'); }
            });
        }

        // Initialize Page
        $(document).ready(function() {
            // Global Event Delegation for Message Context Menu (Right Click & Double Click)
            var feed = document.getElementById("messagesFeed");
            if (feed) {
                var handleMsgAction = function(e) {
                    var bubble = e.target.closest('.message-bubble');
                    if (!bubble) return;
                    var wrapper = bubble.closest('.message-wrapper');
                    if (!wrapper) return;
                    
                    // Check if message is deleted (has fa-ban)
                    if (bubble.innerHTML.indexOf('fa-ban') !== -1) return;

                    var msgId = wrapper.getAttribute('data-msgid');
                    var encodedContent = wrapper.getAttribute('data-content');
                    var rawContent = "";
                    if (encodedContent) {
                        try { rawContent = decodeURIComponent(encodedContent); } 
                        catch(err) { rawContent = encodedContent; }
                    }
                    
                    showMsgContextMenuDirect(e, msgId, rawContent);
                };

                feed.addEventListener('contextmenu', function(e) { handleMsgAction(e); });
                feed.addEventListener('dblclick', function(e) { handleMsgAction(e); });
            }

            initSignalR();
            loadChatsList();
            
            // Close overlays when clicking outside
            $(document).mouseup(function(e) {
                var sheet = $("#attachmentSheet");
                var trigger = $("button[title='Attach file']");
                if (!sheet.is(e.target) && sheet.has(e.target).length === 0 && !trigger.is(e.target) && trigger.has(e.target).length === 0) {
                    sheet.hide();
                }

                var dropdown = $("#headerDropdownMenu");
                var gearBtn = $("button[title='More options']");
                if (!dropdown.is(e.target) && dropdown.has(e.target).length === 0 && !gearBtn.is(e.target) && gearBtn.has(e.target).length === 0) {
                    dropdown.hide();
                }
            });
        });
        // Custom WhatsApp Voice Player Logic
        function toggleWaAudio(id) {
            var audio = document.getElementById(id);
            var icon = document.getElementById('icon-' + id);
            if (audio.paused) {
                audio.play();
                icon.className = 'fas fa-pause';
            } else {
                audio.pause();
                icon.className = 'fas fa-play';
            }
        }

        function updateWaAudio(id) {
            var audio = document.getElementById(id);
            var dot = document.getElementById('dot-' + id);
            var progWrap = document.getElementById('prog-wrap-' + id);
            var timeDisplay = document.getElementById('time-' + id);
            if (!audio || !audio.duration) return;
            
            var percent = (audio.currentTime / audio.duration) * 100;
            progWrap.style.width = percent + '%';
            dot.style.left = percent + '%';
            
            var mins = Math.floor(audio.currentTime / 60);
            var secs = Math.floor(audio.currentTime % 60);
            timeDisplay.textContent = mins + ':' + (secs < 10 ? '0' : '') + secs;
        }

        function initWaAudio(id) {
            var audio = document.getElementById(id);
            var timeDisplay = document.getElementById('time-' + id);
            if (audio && audio.duration && isFinite(audio.duration)) {
                var mins = Math.floor(audio.duration / 60);
                var secs = Math.floor(audio.duration % 60);
                var durText = mins + ':' + (secs < 10 ? '0' : '') + secs;
                timeDisplay.textContent = durText;
                
                // Update any reply bubbles on screen that reference this audio
                var originalMsgId = id.replace('audio-', '');
                var replies = document.querySelectorAll('.reply-bubble-wrapper[data-reply-to-msgid="' + originalMsgId + '"] .reply-dur-text');
                replies.forEach(function(el) {
                    if (el.textContent === 'Voice' || el.textContent === '0:00') {
                        el.textContent = durText;
                    }
                });
            }
        }

        function endWaAudio(id) {
            var icon = document.getElementById('icon-' + id);
            icon.className = 'fas fa-play';
            var dot = document.getElementById('dot-' + id);
            var progWrap = document.getElementById('prog-wrap-' + id);
            if(dot) dot.style.left = '0%';
            if(progWrap) progWrap.style.width = '0%';
            
            var audio = document.getElementById(id);
            if (audio && audio.duration && isFinite(audio.duration)) {
                var timeDisplay = document.getElementById('time-' + id);
                var mins = Math.floor(audio.duration / 60);
                var secs = Math.floor(audio.duration % 60);
                timeDisplay.textContent = mins + ':' + (secs < 10 ? '0' : '') + secs;
            }
        }

        function seekWaAudio(event, id) {
            var audio = document.getElementById(id);
            if (!audio || !audio.duration || !isFinite(audio.duration)) return;
            var container = document.getElementById('wave-' + id);
            var rect = container.getBoundingClientRect();
            var clickX = event.clientX - rect.left;
            var percent = clickX / rect.width;
            if(percent < 0) percent = 0;
            if(percent > 1) percent = 1;
            audio.currentTime = percent * audio.duration;
            updateWaAudio(id);
        }
    </script>
}

