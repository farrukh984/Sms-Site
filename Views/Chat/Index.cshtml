        function forwardSelectedMsgs() {
            var payloads = [];
            selectedMessageIds.forEach(function(msgId) {
                var wrapper = document.querySelector('.message-wrapper[data-msgid="'+msgId+'"]');
                if (wrapper) {
                    var type = wrapper.getAttribute('data-type') || 'Text';
                    var fileUrl = wrapper.getAttribute('data-fileurl') || '';
                    try { fileUrl = decodeURIComponent(fileUrl); } catch(e) {}
                    var content = wrapper.getAttribute('data-content');
                    try { content = decodeURIComponent(content); } catch(e) {}
                    
                    payloads.push({ content: content, type: type, fileUrl: fileUrl });
                }
            });
            if (payloads.length > 0) {
                openForwardModal(payloads);
            } else {
                exitSelectMode();
            }
        }

        // Click handler for message wrappers in select mode
        document.addEventListener('click', function(e) {
