        function loadGroupContacts() {
            var container = document.getElementById('groupMembersListScrollable');
            container.innerHTML = '<div style="text-align: center; color: var(--text-muted); padding: 15px; font-size: 13px;">Loading contacts...</div>';
            
            $.get('/Chat/GetContacts', function(data) {
