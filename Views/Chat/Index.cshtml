            var payloadData = JSON.stringify({ chatIds: _forwardSelectedChatIds, payloads: _forwardPayloads });
            console.log('[Forward] Sending payload:', payloadData);
            
            $.ajax({
                url: '/Chat/ForwardMessages',
                type: 'POST',
                contentType: 'application/json',
                data: payloadData,
                success: function(res) {
                    console.log('[Forward] Server response:', res);
