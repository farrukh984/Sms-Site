        function getActiveMsgData() {
            var wrapper = document.querySelector('.message-wrapper[data-msgid="'+activeContextMsgId+'"]');
            if (!wrapper) return { type: 'Text', fileUrl: '' };
            var type = wrapper.getAttribute('data-type') || 'Text';
            var fileUrl = wrapper.getAttribute('data-fileurl') || '';
            try { fileUrl = decodeURIComponent(fileUrl); } catch(e) {}
            return { type: type, fileUrl: fileUrl, isOutgoing: wrapper.classList.contains('outgoing') };
        }

        function replyToMsg() {
            document.getElementById('messageContextMenu').style.display = 'none';
            activeReplyToMessageId = activeContextMsgId;
            
            var msgData = getActiveMsgData();
            var replyContent = activeContextMsgContent;
            
            // Get sender name from the wrapper
            var wrapper = document.querySelector('.message-wrapper[data-msgid="'+activeContextMsgId+'"]');
            var senderDisplayName = "User";
            if (msgData.isOutgoing) {
                senderDisplayName = "You";
            } else {
                var hdrEl = document.getElementById('activeChatName');
                if (hdrEl) senderDisplayName = hdrEl.textContent.trim();
