                sendTextMessage();
            }
        }

        function sendOrRecord() {
            var icon = document.getElementById("sendOrMicIcon");
            if (icon.classList.contains("fa-paper-plane")) {
                sendTextMessage();
            } else {
                startVoiceRecording();
            }
        }

        function sendTypingIndicator(isTyping) {
            if (!activeChatId) return;

            if (isTyping) {
                if (!isTypingSignalSent) {
                    isTypingSignalSent = true;
                    connection.invoke("SendTyping", activeChatId.toString(), currentUserId.toString(), true);
                }
                
                // Always reset the timer when typing continues
                clearTimeout(typingTimer);
                typingTimer = setTimeout(function() {
                    isTypingSignalSent = false;
                    connection.invoke("SendTyping", activeChatId.toString(), currentUserId.toString(), false);
                }, 4000);
            } else {
                if (isTypingSignalSent) {
                    isTypingSignalSent = false;
                    clearTimeout(typingTimer);
                    connection.invoke("SendTyping", activeChatId.toString(), currentUserId.toString(), false);
                }
            }
        }

        // File attachment triggers
        var fileAttachmentType = "Image";
        function triggerFileUpload(type) {
            fileAttachmentType = type;
            toggleAttachmentSheet();
            document.getElementById("messageFileInput").click();
        }

        function uploadSelectedFile() {
            var fileInput = document.getElementById("messageFileInput");
            if (fileInput.files.length === 0 || !activeChatId) return;

            var file = fileInput.files[0];
            var formData = new FormData();
            formData.append("chatId", activeChatId);
            formData.append("type", fileAttachmentType);
            formData.append("file", file);

            // Upload
            $.ajax({
                url: "/Chat/UploadAttachment",
                type: "POST",
                data: formData,
                processData: false,
                contentType: false,
                success: function(res) {
                    // broadcast SignalR message
                    connection.invoke("SendMessage", activeChatId.toString(), currentUserId.toString(), currentUserFullName, res.fileName, fileAttachmentType, res.fileUrl, res.messageId, activeReplyToMessageId, res.replyToMessageContent || null);
                    fileInput.value = "";
                },
                error: function() {
                    alert("Failed to upload file attachment.");
                }
            });
        }

        // Voice Recording API
        function startVoiceRecording() {
            var modal = document.getElementById("voiceRecordModal");
            var statusText = document.getElementById("recordStatus");
            var timerText = document.getElementById("recordTimer");

            // Display recorder overlay immediately so user sees feedback
            modal.style.display = "flex";
            statusText.textContent = "Requesting microphone access...";
            timerText.textContent = "--:--";

            if (navigator.mediaDevices && navigator.mediaDevices.getUserMedia) {
                navigator.mediaDevices.getUserMedia({ 
                    audio: {
                        echoCancellation: true,
                        noiseSuppression: true,
                        autoGainControl: true
                    } 
                }).then(function(stream) {
                    voiceStream = stream;
                    mediaRecorder = new MediaRecorder(stream);
                    audioChunks = [];

                    mediaRecorder.ondataavailable = function(e) {
                        audioChunks.push(e.data);
                    };

                    mediaRecorder.start();

                    // Broadcast "recording audio..." to others
                    if (activeChatId) {
                        connection.invoke("SendRecording", activeChatId.toString(), currentUserId.toString(), true);
                    }

                    statusText.textContent = "Recording voice message...";
                    recordTimeSec = 0;
                    timerText.textContent = "00:00";
                    
                    clearInterval(recordInterval);
                    recordInterval = setInterval(function() {
                        recordTimeSec++;
                        var mins = Math.floor(recordTimeSec / 60).toString().padStart(2, '0');
                        var secs = (recordTimeSec % 60).toString().padStart(2, '0');
                        timerText.textContent = mins + ":" + secs;
                    }, 1000);

                }).catch(function(err) {
                    modal.style.display = "none";
                    alert("Could not access microphone: " + err.message + "\n\nMake sure your browser allows microphone access and you are using a secure connection (HTTPS or localhost).");
                });
            } else {
                modal.style.display = "none";
                alert("Voice recording is not supported in this browser. Please ensure you are using HTTPS or localhost.");
            }
        }

        function cancelVoiceRecording() {
            if (mediaRecorder) mediaRecorder.stop();
            if (voiceStream) voiceStream.getTracks().forEach(t => t.stop());
            clearInterval(recordInterval);
            // Broadcast recording stopped
            if (activeChatId) connection.invoke("SendRecording", activeChatId.toString(), currentUserId.toString(), false);
            document.getElementById("voiceRecordModal").style.display = "none";
        }

        function stopAndSendVoiceRecording() {
            if (!mediaRecorder) return;

            mediaRecorder.onstop = function() {
                var audioBlob = new Blob(audioChunks, { type: 'audio/webm' });
                var file = new File([audioBlob], "voice_message.webm", { type: 'audio/webm' });

                var formData = new FormData();
                formData.append("chatId", activeChatId);
                formData.append("type", "Audio");
                formData.append("file", file);

                $.ajax({
                    url: "/Chat/UploadAttachment",
                    type: "POST",
                    data: formData,
                    processData: false,
                    contentType: false,
                    success: function(res) {
                        connection.invoke("SendMessage", activeChatId.toString(), currentUserId.toString(), currentUserFullName, "Voice Message", "Audio", res.fileUrl, res.messageId, activeReplyToMessageId, res.replyToMessageContent || null);
                    }
                });
            };

            mediaRecorder.stop();
            if (voiceStream) voiceStream.getTracks().forEach(t => t.stop());
            clearInterval(recordInterval);
            // Broadcast recording stopped
            if (activeChatId) connection.invoke("SendRecording", activeChatId.toString(), currentUserId.toString(), false);
            document.getElementById("voiceRecordModal").style.display = "none";
        }

        // Camera capture attachment API
        function triggerCameraCapture() {
            toggleAttachmentSheet();
            if (navigator.mediaDevices && navigator.mediaDevices.getUserMedia) {
                navigator.mediaDevices.getUserMedia({ video: true }).then(function(stream) {
                    cameraStream = stream;
                    var video = document.getElementById("cameraVideo");
                    video.srcObject = stream;
                    document.getElementById("cameraModal").style.display = "flex";
                }).catch(function(err) {
                    alert("Could not access webcam: " + err.message);
                });
            } else {
                alert("Camera is not supported in this browser.");
            }
        }

        function snapPhoto() {
            var video = document.getElementById("cameraVideo");
            var canvas = document.getElementById("cameraCanvas");
            var ctx = canvas.getContext("2d");

            canvas.width = video.videoWidth;
            canvas.height = video.videoHeight;
            ctx.drawImage(video, 0, 0, canvas.width, canvas.height);

            canvas.toBlob(function(blob) {
                var file = new File([blob], "camera_snap.jpg", { type: 'image/jpeg' });
                
                var formData = new FormData();
                formData.append("chatId", activeChatId);
                formData.append("type", "Image");
                formData.append("file", file);

                $.ajax({
                    url: "/Chat/UploadAttachment",
                    type: "POST",
                    data: formData,
                    processData: false,
                    contentType: false,
                    success: function(res) {
                        connection.invoke("SendMessage", activeChatId.toString(), currentUserId.toString(), currentUserFullName, "Photo", "Image", res.fileUrl, res.messageId, activeReplyToMessageId, res.replyToMessageContent || null);
                        closeCameraModal();
                    }
                });
            }, 'image/jpeg');
        }

        function closeCameraModal() {
            if (cameraStream) cameraStream.getTracks().forEach(t => t.stop());
            document.getElementById("cameraModal").style.display = "none";
        }

