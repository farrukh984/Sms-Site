        function toggleGroupMemberSelection(userId, element) {
            var checkbox = element.querySelector('.group-member-checkbox');
            var index = selectedGroupMemberIds.indexOf(userId);

            if (index > -1) {
                selectedGroupMemberIds.splice(index, 1);
                element.style.background = 'transparent';
                if (checkbox) checkbox.checked = false;
            } else {
                selectedGroupMemberIds.push(userId);
                element.style.background = 'rgba(254, 76, 76, 0.1)';
                if (checkbox) checkbox.checked = true;
            }

            var count = selectedGroupMemberIds.length;
            document.getElementById('groupSelectedCount').textContent = count + ' member' + (count === 1 ? '' : 's') + ' selected';
            
            var nextBtn = document.getElementById('groupNextBtn');
            if (count > 0) {
                nextBtn.style.display = 'block';
            } else {
                nextBtn.style.display = 'none';
            }
        }

