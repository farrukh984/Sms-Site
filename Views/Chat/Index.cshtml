        });

        // ---------------------------------

        // Send Text Message
        function sendTextMessage() {
            var input = document.getElementById("chatMessageInput");
            var text = input.value.trim();
            if (text === "" || !activeChatId) return;

            input.value = "";
            document.getElementById("sendOrMicIcon").className = "fas fa-microphone";

            // Save to DB (with limit check)
            $.post("/Chat/SaveTextMessage", { chatId: activeChatId, content: text, replyToMessageId: activeReplyToMessageId }, function(res) {
                if (res && res.limited) {
                    // Put text back and show limit banner
                    input.value = text;
                    document.getElementById("sendOrMicIcon").className = "fas fa-paper-plane";
                    showMessageLimitBanner(res.sentCount || 5);
                    return;
                }
                // broadcast via SignalR
                connection.invoke("SendMessage", activeChatId.toString(), currentUserId.toString(), currentUserFullName, text, "Text", null, res.messageId, activeReplyToMessageId, res.replyToMessageContent);
                cancelReply();
            });

            // Signal typing stopped
            sendTypingIndicator(false);
        }

        // Show limit warning banner inside chat
        function showMessageLimitBanner(sentCount) {
            var existing = document.getElementById('msgLimitBanner');
            if (existing) return;
            var feed = document.getElementById('messagesFeed');
            var banner = document.createElement('div');
            banner.id = 'msgLimitBanner';
            banner.style.cssText = 'position:sticky; bottom:0; left:0; right:0; background:linear-gradient(135deg,rgba(254,76,76,0.15),rgba(254,76,76,0.08)); border:1px solid rgba(254,76,76,0.3); border-radius:14px; padding:14px 18px; margin:12px 0 6px; text-align:center; backdrop-filter:blur(10px);';
            banner.innerHTML = `
                <div style="font-size:13px; color:white; font-weight:600; margin-bottom:4px;">
                    <i class="fas fa-lock" style="color:var(--accent-red); margin-right:8px;"></i>Message limit reached (${sentCount}/5)
                </div>
                <div style="font-size:12px; color:var(--text-secondary); line-height:1.5;">
                    You can only send 5 messages until this person adds you to their contacts.
                </div>
            `;
            feed.appendChild(banner);
            feed.scrollTop = feed.scrollHeight;
        }

        function removeMessageLimitBanner() {
            var b = document.getElementById('msgLimitBanner');
            if (b) b.remove();
        }

        // Input monitoring for typing indicators and microphone toggle
        function handleTyping() {
            var input = document.getElementById("chatMessageInput");
            var btnIcon = document.getElementById("sendOrMicIcon");

            if (input.value.trim() !== "") {
                btnIcon.className = "fas fa-paper-plane"; // Change microphone to Send icon
                sendTypingIndicator(true);
            } else {
                btnIcon.className = "fas fa-microphone";
                sendTypingIndicator(false);
            }
