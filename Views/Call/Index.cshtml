@model List<Site.Models.CallLog>
@functions {
    public string NormalizePhoneNumber(string number)
    {
        if (string.IsNullOrEmpty(number)) return string.Empty;
        var digits = new string(number.Where(char.IsDigit).ToArray());
        if (digits.Length >= 10)
        {
            return digits.Substring(digits.Length - 10);
        }
        return digits;
    }
}
@{
    ViewData["Title"] = "Calls";
    Layout = "~/Views/Shared/_Layout_Chat.cshtml";
    var currentUserId = ViewBag.CurrentUserId as int?;
    var currentUser = ViewBag.CurrentUser as Site.Models.Users;

    // Retrieve contacts for contact checking
    var dbContext = ViewContext.HttpContext.RequestServices.GetService(typeof(Site.Data.AppDbContext)) as Site.Data.AppDbContext;
    List<Site.Models.Contact> userContacts = new List<Site.Models.Contact>();
    if (dbContext != null && currentUserId.HasValue)
    {
        userContacts = dbContext.Contacts.Where(c => c.OwnerId == currentUserId.Value).ToList();
    }
}

<style>
    /* ─── Calls Page Styles (Overriding and matching the main layout) ─── */
    .calls-activity-list {
        display: flex;
        flex-direction: column;
        gap: 12px;
        margin-top: 15px;
    }

    .calls-activity-item {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 12px 16px;
        background: var(--bg-card);
        border-radius: 12px;
        border: 1px solid var(--border-color);
        font-size: 13.5px;
    }

    .calls-activity-meta {
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .calls-activity-time {
        color: var(--text-secondary);
        font-weight: 500;
    }

    .calls-activity-duration {
        color: var(--text-muted);
        font-size: 12px;
    }

    /* Font override - clean out the cursive script */
    .calls-header-title,
    .chat-panel-title-bar h2,
    .chat-item-name,
    .calls-section-label,
    .quick-action-label {
        font-family: var(--font-family) !important;
    }

    /* Direction arrows */
    .arrow-outgoing {
        color: var(--accent-green, #25D366) !important;
    }
    .arrow-incoming {
        color: var(--accent-green, #25D366) !important;
    }
    .arrow-missed {
        color: var(--accent-red, #ff4d4f) !important;
    }

    /* Contact Details Drawer Cards */
    .profile-card-premium {
        background: var(--bg-panel);
        border: 1px solid var(--border-color);
        border-radius: 20px;
        padding: 24px;
        box-shadow: var(--shadow-outset);
        margin: 20px;
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
    }

    .profile-avatar-large {
        width: 110px;
        height: 110px;
        border-radius: 50%;
        object-fit: cover;
        box-shadow: var(--shadow-outset);
        border: 3px solid rgba(255, 255, 255, 0.05);
        transition: transform 0.3s ease;
    }

    .profile-avatar-large:hover {
        transform: scale(1.05);
    }

    .profile-info-row {
        width: 100%;
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 12px 0;
        border-bottom: 1px solid rgba(255, 255, 255, 0.02);
    }

    .profile-info-row:last-child {
        border-bottom: none;
    }

    .profile-info-label {
        color: var(--text-secondary);
        font-size: 13.5px;
        font-weight: 500;
    }

    .profile-info-value {
        color: var(--text-primary);
        font-size: 13.5px;
        font-weight: 600;
    }

    /* Action bar */
    .profile-actions-bar {
        display: flex;
        gap: 15px;
        margin: 20px 0 10px;
        justify-content: center;
        width: 100%;
    }

    .profile-action-btn {
        flex: 1;
        padding: 12px;
        border-radius: 12px;
        font-weight: 600;
        font-size: 13.5px;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        transition: var(--transition);
    }

    /* Responsive Panel Toggling */
    @@media (max-width: 768px) {
        .chat-list-panel {
            width: 100% !important;
        }

        .chat-workspace-panel {
            display: none !important;
            width: 100% !important;
            position: absolute;
            top: 0;
            left: 0;
            height: 100%;
            z-index: 500;
            background: var(--bg-main);
        }

        .chat-workspace-panel.active {
            display: flex !important;
        }
    }
</style>

<div class="chat-app-layout">
    <!-- Column 1 (Far Left Navigation Menu) -->
    @await Html.PartialAsync("_NavSidebar", "Call")

    <!-- Column 2 (Middle Calls List Panel) -->
    <div class="chat-list-panel" id="callsListPanel">
        <!-- Panel A: Recent Calls -->
        <div id="callsMainPanelContainer" style="display: flex; flex-direction: column; height: 100%;">
            <div class="chat-panel-header">
                <div class="chat-panel-title-bar">
                    <div style="display:flex; align-items:center; gap:12px;">
                        <div class="chat-item-avatar" style="width:36px; height:36px; border-radius:50%; overflow:hidden; background:var(--bg-main);">
                            <img src="@(!string.IsNullOrEmpty(currentUser?.ProfilePicture) ? currentUser.ProfilePicture : "/images/default-avatar.svg")" alt="Me" style="width:100%; height:100%; object-fit:cover;"/>
                        </div>
                        <h2>Calls</h2>
                    </div>
                    <button class="neu-btn neu-btn-circle" onclick="showNewCallContactsPanel()" style="width: 36px; height: 36px; display:flex; align-items:center; justify-content:center;" title="New Call">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" style="width: 16px; height: 16px; color: var(--accent-red);">
                            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
                            <line x1="19" y1="2" x2="19" y2="8" stroke-linecap="round" stroke-linejoin="round"></line>
                            <line x1="16" y1="5" x2="22" y2="5" stroke-linecap="round" stroke-linejoin="round"></line>
                        </svg>
                    </button>
                </div>

                <div class="chat-search-container">
                    <input type="text" id="callSearchInput" class="neu-input" placeholder="Search call history..." onkeyup="filterCallLogs()" />
                </div>

                <div class="chat-filters">
                    <div class="chat-filter-pill active" onclick="setCallFilter('all', this)">All</div>
                    <div class="chat-filter-pill" onclick="setCallFilter('missed', this)">Missed</div>
                </div>
            </div>

            <div class="chat-list-scrollable" id="callsContainer">
                @if (Model != null && Model.Any())
                {
                    @foreach (var call in Model)
                    {
                        var isOutgoing = call.CallerId == currentUserId;
                        var otherUser = isOutgoing ? call.Receiver : call.Caller;
                        var otherName = otherUser?.FullName ?? otherUser?.Username ?? "Unknown";
                        var initials = otherName.Length > 0 ? otherName[0].ToString().ToUpper() : "?";

                        var isMissed = call.Status == "Missed" || call.Status == "Rejected";
                        var arrowClass = isMissed ? "arrow-missed" : (isOutgoing ? "arrow-outgoing" : "arrow-incoming");
                        var arrowIcon = isOutgoing ? "fas fa-arrow-up-right" : "fas fa-arrow-down-left";

                        string duration = "";
                        if (call.Status == "Completed" && call.DurationSeconds > 0)
                        {
                            if (call.DurationSeconds >= 3600)
                                duration = $"{call.DurationSeconds / 3600}h {(call.DurationSeconds % 3600) / 60}m";
                            else if (call.DurationSeconds >= 60)
                                duration = $"{call.DurationSeconds / 60}m {call.DurationSeconds % 60}s";
                            else
                                duration = $"{call.DurationSeconds}s";
                        }
                        else if (isMissed)
                        {
                            duration = call.Status == "Rejected" ? "Rejected" : "No answer";
                        }

                        var callIcon = call.CallType == "Video" ? "fas fa-video" : "fas fa-phone";
                        var timeStr = call.StartedAt.ToLocalTime().ToString("h:mm tt");
                        var dateStr = call.StartedAt.ToLocalTime().Date == DateTime.Today
                                      ? $"Today, {timeStr}"
                                      : (call.StartedAt.ToLocalTime().Date == DateTime.Today.AddDays(-1)
                                          ? $"Yesterday, {timeStr}"
                                          : call.StartedAt.ToLocalTime().ToString("MMM d, ") + timeStr);

                        var otherMobileNormalized = otherUser?.MobileNumber != null ? NormalizePhoneNumber(otherUser.MobileNumber) : "";
                        var matchedContact = userContacts.FirstOrDefault(c => NormalizePhoneNumber(c.ContactNumber) == otherMobileNormalized);
                        var isContact = matchedContact != null;
                        var contactId = matchedContact?.Id ?? 0;

                        <div class="chat-item animate-scale-in" 
                             data-callid="@call.Id" 
                             data-status="@call.Status" 
                             data-name="@otherName"
                             data-phone="@(otherUser?.MobileNumber ?? "")"
                             data-json="@System.Text.Json.JsonSerializer.Serialize(new {
                                 id = call.Id,
                                 otherUserId = otherUser?.Id ?? 0,
                                 name = otherName,
                                 avatar = otherUser?.ProfilePicture ?? "/images/default-avatar.svg",
                                 username = otherUser?.Username ?? "user",
                                 email = otherUser?.Email ?? "No email",
                                 phone = otherUser?.MobileNumber ?? "No number",
                                 joinedDate = otherUser?.CreatedAt.ToString("MMMM dd, yyyy") ?? "",
                                 isOutgoing = isOutgoing,
                                 callType = call.CallType,
                                 dateStr = dateStr,
                                 duration = duration,
                                 startedAt = call.StartedAt.ToString("o"),
                                 isContact = isContact,
                                 contactId = contactId
                             })"
                             onclick="selectCallLog(this)">
                            <div class="chat-item-avatar">
                                @if (!string.IsNullOrEmpty(otherUser?.ProfilePicture))
                                {
                                    <img src="@otherUser.ProfilePicture" alt="@otherName" />
                                }
                                else
                                {
                                    <div style="width:100%; height:100%; display:flex; align-items:center; justify-content:center; background:var(--bg-card); font-weight:700; color:var(--text-primary);">@initials</div>
                                }
                            </div>
                            <div class="chat-item-details">
                                <div class="chat-item-name">@otherName</div>
                                <div class="chat-item-message">
                                    <i class="@arrowIcon @arrowClass mr-1" style="font-size: 11px;"></i>
                                    <span class="chat-item-time-text @(isMissed ? "arrow-missed" : "text-gray-400")">@dateStr</span>
                                    @if (!string.IsNullOrEmpty(duration))
                                    {
                                        <span> · @duration</span>
                                    }
                                </div>
                            </div>
                            <div class="chat-item-meta" style="justify-content: center;">
                                <button class="neu-btn neu-btn-circle hover-glow" 
                                        style="width: 36px; height: 36px; display: flex; align-items: center; justify-content: center; background: transparent; border: none; box-shadow: none;" 
                                        onclick="event.stopPropagation(); startCallFromLogs('@(otherUser?.Id ?? 0)', '@call.CallType')" 
                                        title="Call Back">
                                    <i class="@callIcon" style="font-size: 13px; color: var(--accent-red);"></i>
                                </button>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div style="text-align: center; color: var(--text-muted); padding: 60px 20px;">
                        <i class="fas fa-phone-slash" style="font-size: 44px; opacity: 0.3; margin-bottom: 15px; display: block;"></i>
                        <div style="font-size: 15px; font-weight: 600; color: var(--text-primary); margin-bottom: 6px;">No recent calls</div>
                        <div style="font-size: 13px;">Your call activity will appear here</div>
                    </div>
                }
            </div>
        </div>

        <!-- Panel B: Contacts Picker for New Call -->
        <div id="newCallPanelContainer" style="display: none; flex-direction: column; height: 100%;">
            <div class="chat-panel-header" style="padding: 20px 20px 15px; border-bottom: 1px solid rgba(255,255,255,0.05); background: rgba(0,0,0,0.2);">
                <div style="display: flex; align-items: center; gap: 15px;">
                    <button class="neu-btn neu-btn-circle" onclick="backToCallLogsMain()" style="width:36px; height:36px; display:flex; align-items:center; justify-content:center; box-shadow:none; background:rgba(255,255,255,0.05); border:none;">
                        <i class="fas fa-arrow-left" style="font-size: 14px; color: var(--text-secondary);"></i>
                    </button>
                    <h2 style="font-size: 18px; font-weight: 700; margin: 0; color: white;">New Call</h2>
                </div>
            </div>
            <div class="chat-search-container" style="padding: 15px 20px 5px;">
                <div style="position:relative;">
                    <i class="fas fa-search" style="position:absolute; left:16px; top:50%; transform:translateY(-50%); color:var(--text-muted); font-size:13px;"></i>
                    <input type="text" id="newCallSearchInput" class="neu-input" placeholder="Search contacts..." onkeyup="filterNewCallContacts()" style="width:100%; padding-left:40px; border-radius:12px; background:rgba(255,255,255,0.02); border:1px solid rgba(255,255,255,0.05);" />
                </div>
            </div>
            <div class="chat-list-scrollable" id="newCallContactsContainer" style="padding: 10px 12px;">
                <div style="text-align: center; color: var(--text-muted); padding: 40px 0;">Loading contacts...</div>
            </div>
        </div>
    </div>

    <!-- Column 3 (Main Call Details Workspace) -->
    <div class="chat-workspace-panel" id="callWorkspacePanel">
        <!-- Default Welcome State -->
        <div class="chat-welcome-state" id="emptyCallState">
            <div class="chat-welcome-icon" style="width: 80px; height: 80px; border-radius: 24px; margin-bottom: 24px;">
                <svg viewBox="0 0 24 24" fill="none" stroke="var(--accent-red)" stroke-width="1.8" style="width: 40px; height: 40px;">
                    <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
                </svg>
            </div>
            <h3 style="font-size: 26px; font-weight: 700; margin-bottom: 12px; font-family: 'Outfit', sans-serif;">Voice & Video Calls</h3>
            <p style="font-size: 15px; color: var(--text-secondary); max-width: 440px; line-height: 1.6; margin-bottom: 24px;">
                Select a call log to view contact details, call log activity history, or initiate a new audio/video call.
            </p>
            <button class="neu-btn neu-btn-red hover-lift" onclick="showNewCallContactsPanel()" style="padding: 12px 28px; border-radius: 12px; font-weight: 700;">Start New Call</button>
        </div>

        <!-- Selected Call View State (Hidden initially) -->
        <div id="activeCallState" style="display: none; flex-direction: column; height: 100%; width: 100%;">
            <!-- Header -->
            <div class="chat-header">
                <div class="chat-header-user">
                    <button class="d-md-none" onclick="goBackToCallsList()" style="margin: 0; padding: 0; width: 30px; height: 30px; display: flex; align-items: center; justify-content: center; background: transparent; border: none; flex-shrink: 0; margin-right: 10px;">
                        <i class="fas fa-arrow-left" style="font-size:16px; color: var(--accent-red);"></i>
                    </button>
                    <div class="chat-header-name" id="workspaceHeaderName">Call Details</div>
                </div>
            </div>

            <!-- Body Details Panel -->
            <div style="flex: 1; overflow-y: auto; padding: 10px 0;">
                <div class="profile-card-premium">
                    <img id="workspaceAvatar" src="/images/default-avatar.svg" class="profile-avatar-large" alt="Profile" />
                    <h3 id="workspaceName" style="font-size: 22px; font-weight: 700; margin: 15px 0 4px; color: white;">Contact Name</h3>
                    <div id="workspaceUsername" style="color: var(--text-secondary); font-size: 14px; font-weight: 500; margin-bottom: 20px;">@@username</div>

                    <!-- Actions Bar -->
                    <div class="profile-actions-bar">
                        <button class="neu-btn profile-action-btn" id="workspaceMsgBtn" style="background: rgba(255,255,255,0.05); color: white; border: 1px solid rgba(255,255,255,0.08);">
                            <i class="fas fa-comment-alt" style="color: var(--accent-red);"></i> Message
                        </button>
                        <button class="neu-btn profile-action-btn" id="workspaceAudioBtn" style="background: rgba(255,255,255,0.05); color: white; border: 1px solid rgba(255,255,255,0.08);">
                            <i class="fas fa-phone" style="color: var(--accent-red);"></i> Audio
                        </button>
                        <button class="neu-btn profile-action-btn" id="workspaceVideoBtn" style="background: var(--accent-red); color: white; border: none; box-shadow: 0 4px 12px rgba(254, 76, 76, 0.3);">
                            <i class="fas fa-video"></i> Video
                        </button>
                    </div>
                </div>

                <div class="profile-card-premium" style="margin-top: 0;">
                    <h4 style="align-self: flex-start; margin-bottom: 15px; font-size: 15px; font-weight: 700; color: white; text-transform: uppercase; letter-spacing: 0.8px;">Contact Information</h4>
                    <div class="profile-info-row">
                        <span class="profile-info-label">Mobile Number</span>
                        <span class="profile-info-value" id="workspacePhone">No phone</span>
                    </div>
                    <div class="profile-info-row">
                        <span class="profile-info-label">Email Address</span>
                        <span class="profile-info-value" id="workspaceEmail">No email</span>
                    </div>
                    <div class="profile-info-row">
                        <span class="profile-info-label">Member Since</span>
                        <span class="profile-info-value" id="workspaceJoined">Joined Date</span>
                    </div>
                </div>

                <div class="profile-card-premium" style="margin-top: 0;">
                    <h4 style="align-self: flex-start; margin-bottom: 10px; font-size: 15px; font-weight: 700; color: white; text-transform: uppercase; letter-spacing: 0.8px;">Call History Activity</h4>
                    <div class="calls-activity-list" id="workspaceActivityList" style="width: 100%;">
                        <!-- Dynamically filled with call logs of selected user -->
                    </div>
                </div>

                <div class="profile-card-premium" id="workspaceDeleteContactCard" style="margin-top: 0; display: none;">
                    <button class="neu-btn profile-action-btn" id="workspaceDeleteContactBtn" style="background: rgba(254, 76, 76, 0.1); color: var(--accent-red); border: 1px solid rgba(254, 76, 76, 0.2); width: 100%; justify-content: center; gap: 8px; border-radius: 12px; font-weight: 600; padding: 12px;">
                        <i class="fas fa-trash-alt"></i> Delete Contact
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        var callFilter = 'all';
        var selectedCallId = null;
        var contactsList = [];
        var allCallLogs = [];

        function formatCallDateTime(utcDateStr) {
            var date = new Date(utcDateStr);
            if (isNaN(date.getTime())) return utcDateStr;
            
            var now = new Date();
            var yesterday = new Date();
            yesterday.setDate(now.getDate() - 1);
            
            var timeStr = date.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
            
            var isToday = now.toDateString() === date.toDateString();
            var isYesterday = yesterday.toDateString() === date.toDateString();
            
            if (isToday) {
                return "Today, " + timeStr;
            } else if (isYesterday) {
                return "Yesterday, " + timeStr;
            } else {
                var options = { month: 'short', day: 'numeric' };
                return date.toLocaleDateString(undefined, options) + ", " + timeStr;
            }
        }

        // Parse logs into dynamic variable
        $(document).ready(function() {
            // Convert server-rendered UTC times to local browser timezone on load
            $('.chat-item[data-callid]').each(function() {
                var item = $(this);
                var log = item.data('json');
                if (log && log.startedAt) {
                    var localFormatted = formatCallDateTime(log.startedAt);
                    item.find('.chat-item-time-text').text(localFormatted);
                }
            });
        });

        function parseCallLogsFromDOM() {
            allCallLogs = [];
            // Parse all item data attributes
            $('.chat-item[data-callid]').each(function() {
                var item = $(this);
                // Extract parameters from onclick attribute or parsing
                // Since inline onClick contains the parameters, we can parse them or attach them
            });
        }

        function filterCallLogs() {
            var query = $('#callSearchInput').val().toLowerCase().trim();
            
            $('.chat-item[data-callid]').each(function() {
                var item = $(this);
                var name = item.attr('data-name').toLowerCase();
                var phone = item.attr('data-phone').toLowerCase();
                var status = item.attr('data-status');
                
                var matchesSearch = name.indexOf(query) !== -1 || phone.indexOf(query) !== -1;
                var matchesFilter = true;
                
                if (callFilter === 'missed') {
                    matchesFilter = (status === 'Missed' || status === 'Rejected');
                }
                
                if (matchesSearch && matchesFilter) {
                    item.show();
                } else {
                    item.hide();
                }
            });
        }

        function setCallFilter(filter, el) {
            callFilter = filter;
            $('.chat-filter-pill').removeClass('active');
            $(el).addClass('active');
            filterCallLogs();
        }

        function showNewCallContactsPanel() {
            $('#callsMainPanelContainer').hide();
            $('#newCallPanelContainer').css('display', 'flex');
            
            if (contactsList.length === 0) {
                loadNewCallContacts();
            }
        }

        function backToCallLogsMain() {
            $('#newCallPanelContainer').hide();
            $('#callsMainPanelContainer').css('display', 'flex');
        }

        function loadNewCallContacts() {
            var container = $('#newCallContactsContainer');
            container.html('<div style="text-align: center; color: var(--text-muted); padding: 40px 0;"><i class="fas fa-spinner fa-spin mr-2"></i>Loading contacts...</div>');
            
            $.get('/Chat/GetContacts', function(data) {
                contactsList = data;
                renderNewCallContacts();
            }).fail(function() {
                container.html('<div style="text-align: center; color: var(--text-muted); padding: 40px 0; color: var(--accent-red);"><i class="fas fa-exclamation-triangle mr-2"></i>Failed to load contacts.</div>');
            });
        }

        function renderNewCallContacts() {
            var container = $('#newCallContactsContainer');
            container.empty();
            
            var query = $('#newCallSearchInput').val().toLowerCase().trim();
            var filtered = contactsList.filter(function(c) {
                var name = (c.fullName || c.FullName || '').toLowerCase();
                var username = (c.username || c.Username || '').toLowerCase();
                var nickname = (c.nickname || c.Nickname || '').toLowerCase();
                return name.indexOf(query) !== -1 || username.indexOf(query) !== -1 || nickname.indexOf(query) !== -1;
            });
            
            if (filtered.length === 0) {
                container.html('<div style="text-align: center; color: var(--text-muted); padding: 40px 0;">No contacts found.</div>');
                return;
            }
            
            filtered.forEach(function(c) {
                var avatar = c.profilePicture || c.ProfilePicture || '/images/default-avatar.svg';
                var name = c.fullName || c.FullName || c.username || c.Username || 'Unknown User';
                var nickname = c.nickname || c.Nickname ? '@@' + (c.nickname || c.Nickname) : '';
                var userId = c.id || c.Id;
                
                var html = `
                    <div class="chat-item animate-scale-in" onclick="startCallFromLogs('${userId}', 'Audio')">
                        <div class="chat-item-avatar">
                            <img src="${avatar}" alt="Avatar" />
                        </div>
                        <div class="chat-item-details">
                            <div class="chat-item-name">${name}</div>
                            <div class="chat-item-message">${nickname}</div>
                        </div>
                        <div class="chat-item-meta" style="flex-direction: row; gap: 8px; justify-content: center; align-items: center; height: 100%;">
                            <button class="neu-btn neu-btn-circle hover-glow" onclick="event.stopPropagation(); startCallFromLogs('${userId}', 'Audio')" style="width: 32px; height: 32px; display: flex; align-items: center; justify-content: center; border: none; background: transparent; box-shadow: none;" title="Voice Call">
                                <i class="fas fa-phone" style="font-size: 12px; color: var(--accent-red);"></i>
                            </button>
                            <button class="neu-btn neu-btn-circle hover-glow" onclick="event.stopPropagation(); startCallFromLogs('${userId}', 'Video')" style="width: 32px; height: 32px; display: flex; align-items: center; justify-content: center; border: none; background: transparent; box-shadow: none;" title="Video Call">
                                <i class="fas fa-video" style="font-size: 12px; color: var(--accent-red);"></i>
                            </button>
                        </div>
                    </div>
                `;
                container.append(html);
            });
        }

        function filterNewCallContacts() {
            renderNewCallContacts();
        }

        function selectCallLog(element) {
            var details = $(element).data('json');
            selectedCallId = details.id;
            
            // Set Workspace Profile
            $('#workspaceAvatar').attr('src', details.avatar);
            $('#workspaceName').text(details.name);
            $('#workspaceUsername').text('@@' + details.username);
            
            // Set Info rows
            $('#workspacePhone').text(details.phone);
            $('#workspaceEmail').text(details.email);
            $('#workspaceJoined').text(details.joinedDate);
            
            // Wire Actions
            $('#workspaceMsgBtn').off('click').on('click', function() {
                startChatWithMessage(details.otherUserId);
            });
            $('#workspaceAudioBtn').off('click').on('click', function() {
                startCallFromLogs(details.otherUserId, 'Audio');
            });
            $('#workspaceVideoBtn').off('click').on('click', function() {
                startCallFromLogs(details.otherUserId, 'Video');
            });

            // Set up Delete Contact Card
            if (details.isContact) {
                $('#workspaceDeleteContactCard').show();
                $('#workspaceDeleteContactBtn').off('click').on('click', function() {
                    deleteContact(details.contactId);
                });
            } else {
                $('#workspaceDeleteContactCard').hide();
            }
            
            // Load and filter Call History with this contact
            renderContactCallActivity(details.otherUserId);
            
            // Display Workspace panel
            $('#emptyCallState').hide();
            $('#activeCallState').css('display', 'flex');
            
            // Mobile toggle
            if (window.innerWidth <= 768) {
                $('#callsListPanel').hide();
                $('#callWorkspacePanel').addClass('active');
            }
            
            // Mark active chat list item
            $('.chat-item').removeClass('active');
            $(element).addClass('active');
        }

        function deleteContact(contactId) {
            Swal.fire({
                title: 'Delete Contact?',
                text: "Are you sure you want to delete this contact from your list?",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: 'var(--accent-red)',
                cancelButtonColor: 'rgba(255,255,255,0.1)',
                confirmButtonText: 'Yes, delete',
                background: 'var(--bg-panel)',
                color: 'var(--text-primary)'
            }).then((result) => {
                if (result.isConfirmed) {
                    $.post('/Chat/DeleteContact', { contactId: contactId }, function(res) {
                        if (res && res.success) {
                            Swal.fire({
                                icon: 'success',
                                title: 'Deleted',
                                text: res.message,
                                timer: 1500,
                                showConfirmButton: false,
                                background: 'var(--bg-panel)',
                                color: 'var(--text-primary)'
                            }).then(() => {
                                window.location.reload();
                            });
                        } else {
                            Swal.fire({
                                icon: 'error',
                                title: 'Error',
                                text: res.message || 'Could not delete contact.',
                                background: 'var(--bg-panel)',
                                color: 'var(--text-primary)',
                                confirmButtonColor: 'var(--accent-red)'
                            });
                        }
                    });
                }
            });
        }

        function renderContactCallActivity(otherUserId) {
            var activityList = $('#workspaceActivityList');
            activityList.empty();
            
            var matchedLogs = [];
            
            // Read from DOM details of all call logs that match this user
            $('.chat-item[data-callid]').each(function() {
                var item = $(this);
                var log = item.data('json');
                if (log && log.otherUserId == otherUserId) {
                    matchedLogs.push(log);
                }
            });
            
            if (matchedLogs.length === 0) {
                activityList.append('<div style="text-align: center; color: var(--text-muted); padding: 15px; font-size: 13px;">No other logs.</div>');
                return;
            }
            
            matchedLogs.forEach(function(log) {
                var isOutgoing = log.isOutgoing;
                var isMissed = log.status === 'Missed' || log.status === 'Rejected';
                var arrowClass = isMissed ? "arrow-missed" : (isOutgoing ? "arrow-outgoing" : "arrow-incoming");
                var arrowIcon = isOutgoing ? "fas fa-arrow-up-right" : "fas fa-arrow-down-left";
                var callIcon = log.callType === 'Video' ? 'fas fa-video' : 'fas fa-phone';
                
                var desc = log.callType + " Call (" + (isOutgoing ? "Outgoing" : "Incoming") + ")";
                var localDateStr = formatCallDateTime(log.startedAt);
                
                var html = `
                    <div class="calls-activity-item animate-scale-in">
                        <div style="display:flex; align-items:center; gap:10px;">
                            <i class="${callIcon}" style="color: var(--accent-red); font-size: 14px; width: 20px; text-align: center;"></i>
                            <div>
                                <div style="font-weight:600; color:white;">${desc}</div>
                                <div class="calls-activity-duration">
                                    <i class="${arrowIcon} ${arrowClass} mr-1" style="font-size: 10px;"></i>
                                    <span>${log.duration || 'No answer'}</span>
                                </div>
                            </div>
                        </div>
                        <div class="calls-activity-meta">
                            <span class="calls-activity-time">${localDateStr}</span>
                        </div>
                    </div>
                `;
                activityList.append(html);
            });
        }

        function goBackToCallsList() {
            if (window.innerWidth <= 768) {
                $('#callWorkspacePanel').removeClass('active');
                $('#callsListPanel').show();
            }
        }

        function startChatWithMessage(targetUserId) {
            $.post('/Chat/StartChat', { targetUserId: targetUserId }, function(response) {
                if (response && response.chatId) {
                    window.location.href = `/Chat?chatId=${response.chatId}`;
                } else {
                    Swal.fire({
                        icon: 'error',
                        title: 'Error',
                        text: 'Could not open conversation.',
                        background: 'var(--bg-panel)',
                        color: 'var(--text-primary)',
                        confirmButtonColor: 'var(--accent-red)'
                    });
                }
            });
        }

        function startCallFromLogs(otherUserId, type) {
            $.post('/Chat/StartChat', { targetUserId: otherUserId }, function(response) {
                if (response && response.chatId) {
                    window.location.href = `/Chat?chatId=${response.chatId}&startCall=${type.toLowerCase()}`;
                } else {
                    Swal.fire({
                        icon: 'error',
                        title: 'Error',
                        text: 'Could not initiate call.',
                        background: 'var(--bg-panel)',
                        color: 'var(--text-primary)',
                        confirmButtonColor: 'var(--accent-red)'
                    });
                }
            });
        }
    </script>
}
