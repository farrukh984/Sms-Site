@model List<Site.Models.CallLog>
@{
    ViewData["Title"] = "Calls";
    Layout = "~/Views/Shared/_Layout_Chat.cshtml";
    var currentUserId = ViewBag.CurrentUserId as int?;
}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Dancing+Script:wght@500;700&display=swap" rel="stylesheet">

<style>
/* ─── Calls Page ─────────────────────────────── */
.calls-page {
    display: flex;
    flex-direction: column;
    height: 100%;
    background: var(--bg-secondary, #111827);
    max-width: 480px;
    margin: 0 auto;
    position: relative;
    font-family: 'Segoe UI', sans-serif;
}

/* Header */
.calls-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 18px 20px 14px;
    background: var(--bg-secondary, #111827);
}
.calls-header-title {
    font-family: 'Dancing Script', cursive;
    font-size: 32px;
    font-weight: 700;
    color: var(--text-primary, #fff);
    letter-spacing: 1px;
}
.calls-header-actions { display: flex; gap: 10px; }
.calls-header-btn {
    width: 36px; height: 36px;
    border-radius: 50%;
    background: rgba(255,255,255,0.06);
    border: none;
    color: var(--text-secondary, #9ca3af);
    font-size: 16px;
    cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    transition: background 0.2s;
}
.calls-header-btn:hover { background: rgba(255,255,255,0.1); }

/* Quick Action Buttons */
.calls-quick-actions {
    display: flex;
    justify-content: space-around;
    padding: 8px 16px 20px;
}
.quick-action {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    cursor: pointer;
}
.quick-action-icon {
    width: 60px; height: 60px;
    border-radius: 50%;
    background: #1f2c34;
    display: flex; align-items: center; justify-content: center;
    font-size: 22px;
    color: #fff;
    transition: background 0.2s, transform 0.15s;
}
.quick-action-icon:hover { background: #2a3942; transform: scale(1.05); }
.quick-action-label {
    font-family: 'Dancing Script', cursive;
    font-size: 16px;
    color: var(--text-secondary, #9ca3af);
    font-weight: 500;
    margin-top: 4px;
}

/* Section heading */
.calls-section-label {
    font-family: 'Dancing Script', cursive;
    font-size: 24px;
    font-weight: 700;
    color: var(--text-primary, #fff);
    padding: 10px 20px 15px;
    letter-spacing: 0.5px;
}

/* Call List */
.calls-list { flex: 1; overflow-y: auto; padding: 0 0 80px; }

.call-item {
    display: flex;
    align-items: center;
    padding: 12px 20px;
    gap: 14px;
    cursor: pointer;
    transition: background 0.15s;
    border-radius: 0;
}
.call-item:hover { background: rgba(255,255,255,0.04); }

.call-avatar {
    width: 48px; height: 48px;
    border-radius: 50%;
    object-fit: cover;
    flex-shrink: 0;
    background: linear-gradient(135deg, #7c3aed, #3b82f6);
    display: flex; align-items: center; justify-content: center;
    font-weight: 700; color: #fff; font-size: 18px;
    overflow: hidden;
}
.call-avatar img { width: 100%; height: 100%; object-fit: cover; border-radius: 50%; }

.call-info { flex: 1; min-width: 0; }
.call-name {
    font-family: 'Dancing Script', cursive;
    font-size: 22px;
    font-weight: 700;
    color: var(--text-primary, #fff);
    margin-bottom: -2px;
    letter-spacing: 0.5px;
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
}
.call-meta {
    display: flex;
    align-items: center;
    gap: 6px;
    font-family: 'Dancing Script', cursive;
    font-size: 18px;
    color: var(--text-secondary, #9ca3af);
}
.call-meta .arrow { font-size: 16px; font-family: 'Segoe UI', sans-serif; font-weight: bold; }
.arrow-outgoing { color: #25d366; }
.arrow-incoming { color: #25d366; }
.arrow-missed   { color: #ef4444; }

.call-type-btn {
    width: 38px; height: 38px;
    background: transparent;
    border: none;
    color: var(--text-primary, #fff);
    font-size: 18px;
    display: flex; align-items: center; justify-content: center;
    cursor: pointer;
    transition: color 0.2s;
    flex-shrink: 0;
}
.call-type-btn:hover { color: #25d366; }

/* FAB */
.calls-fab {
    position: fixed;
    bottom: 85px;
    right: calc(50% - 220px);
    width: 60px; height: 60px;
    background: #25d366;
    border-radius: 18px; /* Squircle */
    display: flex; align-items: center; justify-content: center;
    color: #111;
    font-size: 24px;
    box-shadow: 0 4px 12px rgba(37,211,102,0.3);
    cursor: pointer;
    transition: transform 0.2s;
    z-index: 100;
}
.calls-fab:hover { transform: scale(1.05); }
@@media (max-width: 480px) {
    .calls-fab { right: 20px; }
}

/* Empty State */
.calls-empty {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 60px 20px;
    color: var(--text-secondary, #9ca3af);
    text-align: center;
}
.calls-empty .icon { font-size: 52px; margin-bottom: 16px; opacity: 0.5; }
.calls-empty .title { font-size: 17px; font-weight: 600; color: var(--text-primary, #fff); margin-bottom: 8px; }
.calls-empty .sub { font-size: 14px; }

@@media (max-width: 500px) {
    .calls-fab { right: 20px; }
}
</style>

<div class="calls-page">

    <!-- Header -->
    <div class="calls-header">
        <div class="calls-header-title">Calls</div>
        <div class="calls-header-actions">
            <button class="calls-header-btn" title="Search"><i class="fas fa-search"></i></button>
            <button class="calls-header-btn" title="More options"><i class="fas fa-ellipsis-v"></i></button>
        </div>
    </div>

    <!-- Quick Action Buttons -->
    <div class="calls-quick-actions">
        <div class="quick-action" onclick="window.location.href='/Chat'">
            <div class="quick-action-icon"><i class="fas fa-phone"></i></div>
            <span class="quick-action-label">Call</span>
        </div>
        <div class="quick-action">
            <div class="quick-action-icon"><i class="fas fa-calendar-alt"></i></div>
            <span class="quick-action-label">Schedule</span>
        </div>
        <div class="quick-action">
            <div class="quick-action-icon"><i class="fas fa-th"></i></div>
            <span class="quick-action-label">Keypad</span>
        </div>
        <div class="quick-action">
            <div class="quick-action-icon"><i class="fas fa-heart"></i></div>
            <span class="quick-action-label">Favorites</span>
        </div>
    </div>

    <!-- Recent Calls -->
    @if (Model != null && Model.Any())
    {
        <div class="calls-section-label">Recent</div>
        <div class="calls-list">
            @foreach (var call in Model)
            {
                var isOutgoing = call.CallerId == currentUserId;
                var otherUser  = isOutgoing ? call.Receiver : call.Caller;
                var otherName  = otherUser?.FullName ?? otherUser?.Username ?? "Unknown";
                var initials   = otherName.Length > 0 ? otherName[0].ToString().ToUpper() : "?";

                var isMissed   = call.Status == "Missed";
                var arrowClass = isMissed ? "arrow-missed" :
                                 isOutgoing ? "arrow-outgoing" : "arrow-incoming";
                var arrowIcon  = isOutgoing ? "fas fa-arrow-up-right" : "fas fa-arrow-down-left";

                string duration = "";
                if (call.Status == "Completed" && call.DurationSeconds > 0)
                {
                    if (call.DurationSeconds >= 3600)
                        duration = $"{call.DurationSeconds / 3600}h {(call.DurationSeconds % 3600) / 60}m";
                    else if (call.DurationSeconds >= 60)
                        duration = $"{call.DurationSeconds / 60} min";
                    else
                        duration = $"{call.DurationSeconds} sec";
                }
                else if (isMissed)
                {
                    duration = "No answer";
                }

                var callIcon = call.CallType == "Video" ? "fas fa-video" : "fas fa-phone";
                var timeStr  = call.StartedAt.ToLocalTime().ToString("h:mm tt");
                var dateStr  = call.StartedAt.ToLocalTime().Date == DateTime.Today
                               ? $"Today, {timeStr}"
                               : call.StartedAt.ToLocalTime().ToString("MMM d, ") + timeStr;

                <div class="call-item">
                    <div class="call-avatar">
                        @if (!string.IsNullOrEmpty(otherUser?.ProfilePicture))
                        {
                            <img src="@otherUser.ProfilePicture" alt="@otherName" />
                        }
                        else
                        {
                            @initials
                        }
                    </div>
                    <div class="call-info">
                        <div class="call-name">@otherName</div>
                        <div class="call-meta">
                            <i class="@arrowIcon arrow @arrowClass"></i>
                            <span class="@(isMissed ? "arrow-missed" : "")">@dateStr</span>
                            @if (!string.IsNullOrEmpty(duration))
                            {
                                <span>· @duration</span>
                            }
                        </div>
                    </div>
                    <button class="call-type-btn" title="@call.CallType call" onclick="window.location.href='/Chat'">
                        <i class="@callIcon"></i>
                    </button>
                </div>
            }
        </div>
    }
    else
    {
        <div class="calls-empty">
            <div class="icon"><i class="fas fa-phone-slash"></i></div>
            <div class="title">No recent calls</div>
            <div class="sub">Your call history will appear here</div>
        </div>
    }

    <!-- Floating Action Button -->
    <button class="calls-fab" onclick="window.location.href='/Chat'" title="New call">
        <i class="fas fa-phone-plus"></i>
    </button>

</div>
