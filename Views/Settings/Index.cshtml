@model Site.Models.Users
@{
    ViewData["Title"] = "Settings";
}

@section MiddlePanel {
    <div class="lp-header" style="height: 60px;">
        <h1>Settings</h1>
    </div>

    <div class="lp-search">
        <div class="search-box">
            <i class="fas fa-search"></i>
            <input type="text" placeholder="Search" />
        </div>
    </div>

    <div class="list-content">
        <!-- Profile Header -->
        <div style="padding: 20px 15px; display: flex; flex-direction: column; align-items: center; position: relative; border-bottom: 1px solid var(--wa-border);">
            <div style="width: 100px; height: 100px; border-radius: 50%; overflow: hidden; margin-bottom: 15px; position: relative;">
                <img src="@(string.IsNullOrEmpty(Model.ProfilePicture) ? $"https://ui-avatars.com/api/?name={System.Net.WebUtility.UrlEncode(Model.FullName ?? Model.Username)}&background=00a884&color=fff" : Model.ProfilePicture)" style="width: 100%; height: 100%; object-fit: cover;" />
                <div style="position: absolute; bottom: 0; background: rgba(0,0,0,0.3); color: white; width: 100%; text-align: center; font-size: 11px; padding: 2px 0;">
                    @(Model.About ?? "Battery about to die")
                </div>
            </div>
            <h2 style="font-size: 20px; font-weight: 500; margin-bottom: 20px; text-transform: uppercase;">@(Model.FullName ?? Model.Username)</h2>
        </div>

        <!-- Settings List -->
        <div style="padding: 10px 0;">
            <div onclick="window.location.href='/Settings/Edit'" style="padding: 15px 20px; display: flex; align-items: center; gap: 20px; cursor: pointer;">
                <i class="far fa-user-circle" style="font-size: 20px; color: var(--wa-icon);"></i>
                <div>
                    <div style="font-size: 16px;">Profile</div>
                    <div style="font-size: 13px; color: var(--wa-text-secondary);">Name, profile photo</div>
                </div>
            </div>
            
            <div onclick="window.location.href='/Settings/Account'" style="padding: 15px 20px; display: flex; align-items: center; gap: 20px; cursor: pointer;">
                <i class="fas fa-key" style="font-size: 20px; color: var(--wa-icon);"></i>
                <div>
                    <div style="font-size: 16px;">Account</div>
                    <div style="font-size: 13px; color: var(--wa-text-secondary);">Security notifications, account info</div>
                </div>
            </div>

            <div onclick="window.location.href='/Settings/Privacy'" style="padding: 15px 20px; display: flex; align-items: center; gap: 20px; cursor: pointer;">
                <i class="fas fa-lock" style="font-size: 20px; color: var(--wa-icon);"></i>
                <div>
                    <div style="font-size: 16px;">Privacy</div>
                    <div style="font-size: 13px; color: var(--wa-text-secondary);">Blocked contacts, disappearing messages</div>
                </div>
            </div>

            <div onclick="window.location.href='/Settings/Chats'" style="padding: 15px 20px; display: flex; align-items: center; gap: 20px; cursor: pointer;">
                <i class="fas fa-comment-dots" style="font-size: 20px; color: var(--wa-icon);"></i>
                <div>
                    <div style="font-size: 16px;">SMS SITE</div>
                    <div style="font-size: 13px; color: var(--wa-text-secondary);">Theme, wallpaper, SMS SITE settings</div>
                </div>
            </div>

            <div onclick="window.location.href='/Settings/Notifications'" style="padding: 15px 20px; display: flex; align-items: center; gap: 20px; cursor: pointer;">
                <i class="far fa-bell" style="font-size: 20px; color: var(--wa-icon);"></i>
                <div>
                    <div style="font-size: 16px;">Notifications</div>
                    <div style="font-size: 13px; color: var(--wa-text-secondary);">Messages, groups, sounds</div>
                </div>
            </div>

            <div onclick="document.getElementById('shortcutsModal').style.display='flex'" style="padding: 15px 20px; display: flex; align-items: center; gap: 20px; cursor: pointer;">
                <i class="fas fa-keyboard" style="font-size: 20px; color: var(--wa-icon);"></i>
                <div>
                    <div style="font-size: 16px;">Keyboard shortcuts</div>
                    <div style="font-size: 13px; color: var(--wa-text-secondary);">Quick actions</div>
                </div>
            </div>

            <div onclick="window.location.href='/Settings/Help'" style="padding: 15px 20px; display: flex; align-items: center; gap: 20px; cursor: pointer;">
                <i class="far fa-question-circle" style="font-size: 20px; color: var(--wa-icon);"></i>
                <div>
                    <div style="font-size: 16px;">Help and feedback</div>
                    <div style="font-size: 13px; color: var(--wa-text-secondary);">Help center, contact us, privacy policy</div>
                </div>
            </div>

            <div onclick="window.location.href='/Auth/Logout'" style="padding: 15px 20px; display: flex; align-items: center; gap: 20px; cursor: pointer; color: #ea0038;">
                <i class="fas fa-sign-out-alt" style="font-size: 20px;"></i>
                <div style="font-size: 16px; font-weight: 500;">Log out</div>
            </div>
        </div>
    </div>
}

@await Html.PartialAsync("~/Views/Home/Index.cshtml")

<!-- Keyboard Shortcuts Modal -->
<div id="shortcutsModal" style="position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.55); display: none; align-items: center; justify-content: center; z-index: 2000;">
    <div style="background: var(--wa-list); width: 850px; max-width: 90%; border-radius: 12px; padding: 40px 50px; box-shadow: 0 4px 30px rgba(0,0,0,0.2); display: flex; flex-direction: column;">
        <h2 style="font-size: 28px; font-weight: 400; margin-bottom: 40px; color: var(--wa-text);">Keyboard shortcuts</h2>
        
        <div style="display: flex; gap: 60px; flex-wrap: wrap;">
            <!-- Column 1 -->
            <div style="flex: 1; min-width: 300px; display: flex; flex-direction: column; gap: 25px;">
                <div style="display: flex; justify-content: space-between; align-items: center;">
                    <span style="font-size: 15px; color: var(--wa-text);">Mark as unread</span>
                    <div style="display: flex; gap: 5px;">
                        <span style="background: #e9edef; color: #54656f; padding: 4px 8px; border-radius: 4px; font-size: 13px; font-weight: 500; border: 1px solid #d1d7db;">Ctrl</span>
                        <span style="background: #e9edef; color: #54656f; padding: 4px 8px; border-radius: 4px; font-size: 13px; font-weight: 500; border: 1px solid #d1d7db;">Alt</span>
                        <span style="background: #e9edef; color: #54656f; padding: 4px 8px; border-radius: 4px; font-size: 13px; font-weight: 500; border: 1px solid #d1d7db;">Shift</span>
                        <span style="background: #e9edef; color: #54656f; padding: 4px 8px; border-radius: 4px; font-size: 13px; font-weight: 500; border: 1px solid #d1d7db;">U</span>
                    </div>
                </div>

                <div style="display: flex; justify-content: space-between; align-items: center;">
                    <span style="font-size: 15px; color: var(--wa-text);">Archive SMS SITE</span>
                    <div style="display: flex; gap: 5px;">
                        <span style="background: #e9edef; color: #54656f; padding: 4px 8px; border-radius: 4px; font-size: 13px; font-weight: 500; border: 1px solid #d1d7db;">Ctrl</span>
                        <span style="background: #e9edef; color: #54656f; padding: 4px 8px; border-radius: 4px; font-size: 13px; font-weight: 500; border: 1px solid #d1d7db;">Alt</span>
                        <span style="background: #e9edef; color: #54656f; padding: 4px 8px; border-radius: 4px; font-size: 13px; font-weight: 500; border: 1px solid #d1d7db;">Shift</span>
                        <span style="background: #e9edef; color: #54656f; padding: 4px 8px; border-radius: 4px; font-size: 13px; font-weight: 500; border: 1px solid #d1d7db;">E</span>
                    </div>
                </div>

                <div style="display: flex; justify-content: space-between; align-items: center;">
                    <span style="font-size: 15px; color: var(--wa-text);">Search</span>
                    <div style="display: flex; gap: 5px;">
                        <span style="background: #e9edef; color: #54656f; padding: 4px 8px; border-radius: 4px; font-size: 13px; font-weight: 500; border: 1px solid #d1d7db;">Ctrl</span>
                        <span style="background: #e9edef; color: #54656f; padding: 4px 8px; border-radius: 4px; font-size: 13px; font-weight: 500; border: 1px solid #d1d7db;">Alt</span>
                        <span style="background: #e9edef; color: #54656f; padding: 4px 8px; border-radius: 4px; font-size: 13px; font-weight: 500; border: 1px solid #d1d7db;">/</span>
                    </div>
                </div>

                <div style="display: flex; justify-content: space-between; align-items: center;">
                    <span style="font-size: 15px; color: var(--wa-text);">New SMS SITE</span>
                    <div style="display: flex; gap: 5px;">
                        <span style="background: #e9edef; color: #54656f; padding: 4px 8px; border-radius: 4px; font-size: 13px; font-weight: 500; border: 1px solid #d1d7db;">Ctrl</span>
                        <span style="background: #e9edef; color: #54656f; padding: 4px 8px; border-radius: 4px; font-size: 13px; font-weight: 500; border: 1px solid #d1d7db;">Alt</span>
                        <span style="background: #e9edef; color: #54656f; padding: 4px 8px; border-radius: 4px; font-size: 13px; font-weight: 500; border: 1px solid #d1d7db;">N</span>
                    </div>
                </div>

                <div style="display: flex; justify-content: space-between; align-items: center;">
                    <span style="font-size: 15px; color: var(--wa-text);">Previous SMS SITE</span>
                    <div style="display: flex; gap: 5px;">
                        <span style="background: #e9edef; color: #54656f; padding: 4px 8px; border-radius: 4px; font-size: 13px; font-weight: 500; border: 1px solid #d1d7db;">Ctrl</span>
                        <span style="background: #e9edef; color: #54656f; padding: 4px 8px; border-radius: 4px; font-size: 13px; font-weight: 500; border: 1px solid #d1d7db;">Alt</span>
                        <span style="background: #e9edef; color: #54656f; padding: 4px 8px; border-radius: 4px; font-size: 13px; font-weight: 500; border: 1px solid #d1d7db;">Shift</span>
                        <span style="background: #e9edef; color: #54656f; padding: 4px 8px; border-radius: 4px; font-size: 13px; font-weight: 500; border: 1px solid #d1d7db;">Tab</span>
                    </div>
                </div>

                <div style="display: flex; justify-content: space-between; align-items: center;">
                    <span style="font-size: 15px; color: var(--wa-text);">Close SMS SITE</span>
                    <div style="display: flex; gap: 5px;">
                        <span style="background: #e9edef; color: #54656f; padding: 4px 8px; border-radius: 4px; font-size: 13px; font-weight: 500; border: 1px solid #d1d7db;">Escape</span>
                    </div>
                </div>

                <div style="display: flex; justify-content: space-between; align-items: center;">
                    <span style="font-size: 15px; color: var(--wa-text);">Profile and About</span>
                    <div style="display: flex; gap: 5px;">
                        <span style="background: #e9edef; color: #54656f; padding: 4px 8px; border-radius: 4px; font-size: 13px; font-weight: 500; border: 1px solid #d1d7db;">Ctrl</span>
                        <span style="background: #e9edef; color: #54656f; padding: 4px 8px; border-radius: 4px; font-size: 13px; font-weight: 500; border: 1px solid #d1d7db;">Alt</span>
                        <span style="background: #e9edef; color: #54656f; padding: 4px 8px; border-radius: 4px; font-size: 13px; font-weight: 500; border: 1px solid #d1d7db;">P</span>
                    </div>
                </div>
            </div>

            <!-- Column 2 -->
            <div style="flex: 1; min-width: 300px; display: flex; flex-direction: column; gap: 25px;">
                <div style="display: flex; justify-content: space-between; align-items: center;">
                    <span style="font-size: 15px; color: var(--wa-text);">Mute</span>
                    <div style="display: flex; gap: 5px;">
                        <span style="background: #e9edef; color: #54656f; padding: 4px 8px; border-radius: 4px; font-size: 13px; font-weight: 500; border: 1px solid #d1d7db;">Ctrl</span>
                        <span style="background: #e9edef; color: #54656f; padding: 4px 8px; border-radius: 4px; font-size: 13px; font-weight: 500; border: 1px solid #d1d7db;">Alt</span>
                        <span style="background: #e9edef; color: #54656f; padding: 4px 8px; border-radius: 4px; font-size: 13px; font-weight: 500; border: 1px solid #d1d7db;">Shift</span>
                        <span style="background: #e9edef; color: #54656f; padding: 4px 8px; border-radius: 4px; font-size: 13px; font-weight: 500; border: 1px solid #d1d7db;">M</span>
                    </div>
                </div>

                <div style="display: flex; justify-content: space-between; align-items: center;">
                    <span style="font-size: 15px; color: var(--wa-text);">Pin SMS SITE</span>
                    <div style="display: flex; gap: 5px;">
                        <span style="background: #e9edef; color: #54656f; padding: 4px 8px; border-radius: 4px; font-size: 13px; font-weight: 500; border: 1px solid #d1d7db;">Ctrl</span>
                        <span style="background: #e9edef; color: #54656f; padding: 4px 8px; border-radius: 4px; font-size: 13px; font-weight: 500; border: 1px solid #d1d7db;">Alt</span>
                        <span style="background: #e9edef; color: #54656f; padding: 4px 8px; border-radius: 4px; font-size: 13px; font-weight: 500; border: 1px solid #d1d7db;">Shift</span>
                        <span style="background: #e9edef; color: #54656f; padding: 4px 8px; border-radius: 4px; font-size: 13px; font-weight: 500; border: 1px solid #d1d7db;">P</span>
                    </div>
                </div>

                <div style="display: flex; justify-content: space-between; align-items: center;">
                    <span style="font-size: 15px; color: var(--wa-text);">Search SMS SITE</span>
                    <div style="display: flex; gap: 5px;">
                        <span style="background: #e9edef; color: #54656f; padding: 4px 8px; border-radius: 4px; font-size: 13px; font-weight: 500; border: 1px solid #d1d7db;">Ctrl</span>
                        <span style="background: #e9edef; color: #54656f; padding: 4px 8px; border-radius: 4px; font-size: 13px; font-weight: 500; border: 1px solid #d1d7db;">Shift</span>
                        <span style="background: #e9edef; color: #54656f; padding: 4px 8px; border-radius: 4px; font-size: 13px; font-weight: 500; border: 1px solid #d1d7db;">F</span>
                    </div>
                </div>

                <div style="display: flex; justify-content: space-between; align-items: center;">
                    <span style="font-size: 15px; color: var(--wa-text);">Next SMS SITE</span>
                    <div style="display: flex; gap: 5px;">
                        <span style="background: #e9edef; color: #54656f; padding: 4px 8px; border-radius: 4px; font-size: 13px; font-weight: 500; border: 1px solid #d1d7db;">Ctrl</span>
                        <span style="background: #e9edef; color: #54656f; padding: 4px 8px; border-radius: 4px; font-size: 13px; font-weight: 500; border: 1px solid #d1d7db;">Alt</span>
                        <span style="background: #e9edef; color: #54656f; padding: 4px 8px; border-radius: 4px; font-size: 13px; font-weight: 500; border: 1px solid #d1d7db;">Tab</span>
                    </div>
                </div>

                <div style="display: flex; justify-content: space-between; align-items: center;">
                    <span style="font-size: 15px; color: var(--wa-text);">Label SMS SITE</span>
                    <div style="display: flex; gap: 5px;">
                        <span style="background: #e9edef; color: #54656f; padding: 4px 8px; border-radius: 4px; font-size: 13px; font-weight: 500; border: 1px solid #d1d7db;">Ctrl</span>
                        <span style="background: #e9edef; color: #54656f; padding: 4px 8px; border-radius: 4px; font-size: 13px; font-weight: 500; border: 1px solid #d1d7db;">Alt</span>
                        <span style="background: #e9edef; color: #54656f; padding: 4px 8px; border-radius: 4px; font-size: 13px; font-weight: 500; border: 1px solid #d1d7db;">Shift</span>
                        <span style="background: #e9edef; color: #54656f; padding: 4px 8px; border-radius: 4px; font-size: 13px; font-weight: 500; border: 1px solid #d1d7db;">L</span>
                    </div>
                </div>

                <div style="display: flex; justify-content: space-between; align-items: center;">
                    <span style="font-size: 15px; color: var(--wa-text);">New group</span>
                    <div style="display: flex; gap: 5px;">
                        <span style="background: #e9edef; color: #54656f; padding: 4px 8px; border-radius: 4px; font-size: 13px; font-weight: 500; border: 1px solid #d1d7db;">Ctrl</span>
                        <span style="background: #e9edef; color: #54656f; padding: 4px 8px; border-radius: 4px; font-size: 13px; font-weight: 500; border: 1px solid #d1d7db;">Alt</span>
                        <span style="background: #e9edef; color: #54656f; padding: 4px 8px; border-radius: 4px; font-size: 13px; font-weight: 500; border: 1px solid #d1d7db;">Shift</span>
                        <span style="background: #e9edef; color: #54656f; padding: 4px 8px; border-radius: 4px; font-size: 13px; font-weight: 500; border: 1px solid #d1d7db;">N</span>
                    </div>
                </div>

                <div style="display: flex; justify-content: space-between; align-items: center;">
                    <span style="font-size: 15px; color: var(--wa-text);">Increase speed of selected voice message</span>
                    <div style="display: flex; gap: 5px;">
                        <span style="background: #e9edef; color: #54656f; padding: 4px 8px; border-radius: 4px; font-size: 13px; font-weight: 500; border: 1px solid #d1d7db;">Shift</span>
                        <span style="background: #e9edef; color: #54656f; padding: 4px 8px; border-radius: 4px; font-size: 13px; font-weight: 500; border: 1px solid #d1d7db;">.</span>
                    </div>
                </div>
            </div>
        </div>

        <div style="margin-top: 50px; display: flex; justify-content: flex-end;">
            <button onclick="document.getElementById('shortcutsModal').style.display='none'" style="background: #00a884; color: white; border: none; padding: 12px 36px; border-radius: 24px; font-size: 15px; font-weight: 500; cursor: pointer; transition: background 0.2s;">
                OK
            </button>
        </div>
    </div>
</div>

